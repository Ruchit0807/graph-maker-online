---
import AdCard from "./AdCard.astro";
---

<aside 
  id="control-panel" 
  class="fixed inset-y-0 left-0 z-40 w-80 h-full border-r border-hairline bg-canvas-soft flex flex-col overflow-y-auto no-scrollbar shrink-0 select-none print:hidden transition-transform duration-200 ease-in-out -translate-x-full lg:translate-x-0 lg:static lg:w-[360px] shadow-2xl lg:shadow-none"
>
  
  <!-- App Status / Branding info in mobile drawer -->
  <div class="px-6 py-4 border-b border-hairline flex flex-col gap-1.5 bg-canvas/30">
    <div class="flex items-center justify-between">
      <span class="font-mono text-[10px] uppercase tracking-wider text-mute">Workspace Configuration</span>
      
      <!-- Close button on mobile -->
      <button 
        id="close-sidebar-btn" 
        class="lg:hidden h-5 w-5 rounded-full flex items-center justify-center text-mute hover:bg-canvas-soft-2 hover:text-ink focus:outline-none transition-colors border border-hairline bg-canvas"
        title="Close Panel"
      >
        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <span class="hidden lg:inline-flex items-center gap-1 rounded-sm bg-success/15 px-1.5 py-0.5 text-[10px] font-medium text-success">
        Active Session
      </span>
    </div>
    <p class="text-xs text-body font-sans">Traditional grid layouts translated to browser canvas.</p>
  </div>

  <div class="p-6 flex flex-col gap-6">

    <!-- Section: Paper Selection -->
    <div class="flex flex-col gap-2">
      <h4 class="font-sans text-[11px] font-semibold uppercase tracking-wider text-mute">1. Grid Paper Template</h4>
      <div class="grid grid-cols-2 gap-2">
        <!-- University Green (Default) -->
        <button 
          data-grid="green" 
          class="grid-selector flex flex-col items-center justify-center rounded-sm border border-primary bg-canvas p-2.5 text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
        >
          <div class="h-3 w-3 rounded-full bg-univ-green mb-1.5"></div>
          <span class="text-xs font-semibold text-ink">Univ Green</span>
          <span class="text-[9px] text-mute font-mono">Traditional</span>
        </button>

        <!-- Cartesian Grid -->
        <button 
          data-grid="cartesian" 
          class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
        >
          <div class="h-3 w-3 rounded-full bg-blue-500 mb-1.5"></div>
          <span class="text-xs font-medium text-ink">Cartesian XY</span>
          <span class="text-[9px] text-mute font-mono">Standard</span>
        </button>

        <!-- Polar Graph -->
        <button 
          data-grid="polar" 
          class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
        >
          <div class="h-3 w-3 rounded-full border border-hairline bg-transparent mb-1.5 relative flex items-center justify-center">
            <div class="h-1.5 w-1.5 rounded-full bg-primary"></div>
          </div>
          <span class="text-xs font-medium text-ink">Polar Plot</span>
          <span class="text-[9px] text-mute font-mono">Circular</span>
        </button>

        <!-- Semi Log -->
        <button 
          data-grid="semilog" 
          class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
        >
          <div class="flex items-center gap-0.5 mb-1.5">
            <span class="text-[8px] font-mono text-mute">10^Y</span>
          </div>
          <span class="text-xs font-medium text-ink">Semi-Log Y</span>
          <span class="text-[9px] text-mute font-mono">Logarithmic</span>
        </button>

        <!-- Log Log -->
        <button 
          data-grid="loglog" 
          class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
        >
          <div class="flex items-center gap-0.5 mb-1.5">
            <span class="text-[8px] font-mono text-mute">10^XY</span>
          </div>
          <span class="text-xs font-medium text-ink">Log-Log</span>
          <span class="text-[9px] text-mute font-mono">Decades</span>
        </button>

        <!-- Blank Grid -->
        <button 
          data-grid="blank" 
          class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
        >
          <div class="h-3 w-3 rounded-sm border border-dashed border-mute/50 bg-transparent mb-1.5"></div>
          <span class="text-xs font-medium text-ink">Blank Paper</span>
          <span class="text-[9px] text-mute font-mono">Minimal</span>
        </button>
      </div>
    </div>

    <!-- Section: Drawing & Plotting Tools -->
    <div class="flex flex-col gap-2">
      <h4 class="font-sans text-[11px] font-semibold uppercase tracking-wider text-mute">2. Canvas Instruments</h4>
      <div class="grid grid-cols-3 gap-1.5">
        <!-- Plot Point -->
        <button 
          data-tool="point" 
          class="tool-selector flex flex-col items-center justify-center h-14 rounded-sm border border-primary bg-canvas text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
          title="Place Coordinate Point"
        >
          <svg class="h-4.5 w-4.5 text-ink mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="text-[9.5px] font-semibold text-ink">Point</span>
        </button>

        <!-- Pencil (handwriting) -->
        <button 
          data-tool="pencil" 
          class="tool-selector flex flex-col items-center justify-center h-14 rounded-sm border border-hairline bg-canvas text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
          title="Natural Stroke Sketching"
        >
          <svg class="h-4.5 w-4.5 text-body mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
          </svg>
          <span class="text-[9.5px] font-medium text-body">Pencil</span>
        </button>

        <!-- Pen (crisp line) -->
        <button 
          data-tool="pen" 
          class="tool-selector flex flex-col items-center justify-center h-14 rounded-sm border border-hairline bg-canvas text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
          title="Clean Solid Pen Drawing"
        >
          <svg class="h-4.5 w-4.5 text-body mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 4v12l-4 2-4-2V4M6 20h12" />
          </svg>
          <span class="text-[9.5px] font-medium text-body">Pen</span>
        </button>

        <!-- Straight Line -->
        <button 
          data-tool="line" 
          class="tool-selector flex flex-col items-center justify-center h-14 rounded-sm border border-hairline bg-canvas text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
          title="Connect Points with Line"
        >
          <svg class="h-4.5 w-4.5 text-body mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 20L20 4" />
          </svg>
          <span class="text-[9.5px] font-medium text-body">Line</span>
        </button>

        <!-- Polyline -->
        <button 
          data-tool="polyline" 
          class="tool-selector flex flex-col items-center justify-center h-14 rounded-sm border border-hairline bg-canvas text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
          title="Chained Multi-segment Line"
        >
          <svg class="h-4.5 w-4.5 text-body mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 19l4-8 6 6 8-12" />
          </svg>
          <span class="text-[9.5px] font-medium text-body">Polyline</span>
        </button>

        <!-- Smooth Curve -->
        <button 
          data-tool="curve" 
          class="tool-selector flex flex-col items-center justify-center h-14 rounded-sm border border-hairline bg-canvas text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
          title="Smooth Interpolation Spline"
        >
          <svg class="h-4.5 w-4.5 text-body mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 18c6-6 6-12 16-12" />
          </svg>
          <span class="text-[9.5px] font-medium text-body">Spline Curve</span>
        </button>

        <!-- Area Under Curve -->
        <button 
          data-tool="area" 
          class="tool-selector flex flex-col items-center justify-center h-14 rounded-sm border border-hairline bg-canvas text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
          title="Calculate Shaded Integration Area"
        >
          <svg class="h-4.5 w-4.5 text-body mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v20m0-20H4a8 8 0 008 8m0-8h8a8 8 0 01-8 8" />
          </svg>
          <span class="text-[9.5px] font-medium text-body">Find Area</span>
        </button>

        <!-- Measurement (Distance / Angle) -->
        <button 
          data-tool="distance" 
          class="tool-selector flex flex-col items-center justify-center h-14 rounded-sm border border-hairline bg-canvas text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
          title="Measure Euclidean Distance between 2 points"
        >
          <svg class="h-4.5 w-4.5 text-body mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          <span class="text-[9.5px] font-medium text-body">Distance</span>
        </button>

        <!-- Eraser -->
        <button 
          data-tool="eraser" 
          class="tool-selector flex flex-col items-center justify-center h-14 rounded-sm border border-hairline bg-canvas text-center transition-all focus:outline-none hover:bg-canvas-soft-2"
          title="Selectively Erase Elements"
        >
          <svg class="h-4.5 w-4.5 text-body mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-4v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          <span class="text-[9.5px] font-medium text-body text-error">Eraser</span>
        </button>
      </div>

      <!-- Line / Draw Color Selector -->
      <div class="mt-2.5 flex flex-col gap-1.5 rounded-sm border border-hairline bg-canvas/30 p-2.5">
        <span class="font-mono text-[9px] uppercase tracking-wider text-mute">Line / Draw Color</span>
        <div class="flex items-center gap-2">
          <!-- Blue (Default) -->
          <button 
            data-color="#0070f3" 
            class="color-dot-selector h-6 w-6 rounded-full border-2 border-primary bg-[#0070f3] focus:outline-none transition-transform hover:scale-110"
            title="Vercel Blue"
          ></button>
          <!-- Violet -->
          <button 
            data-color="#7928ca" 
            class="color-dot-selector h-6 w-6 rounded-full border border-hairline bg-[#7928ca] focus:outline-none transition-transform hover:scale-110"
            title="Geist Violet"
          ></button>
          <!-- Pink -->
          <button 
            data-color="#ff0080" 
            class="color-dot-selector h-6 w-6 rounded-full border border-hairline bg-[#ff0080] focus:outline-none transition-transform hover:scale-110"
            title="Highlight Pink"
          ></button>
          <!-- Teal -->
          <button 
            data-color="#50e3c2" 
            class="color-dot-selector h-6 w-6 rounded-full border border-hairline bg-[#50e3c2] focus:outline-none transition-transform hover:scale-110"
            title="Spotlight Teal"
          ></button>
           <!-- Orange -->
          <button 
            data-color="#f5a623" 
            class="color-dot-selector h-6 w-6 rounded-full border border-hairline bg-[#f5a623] focus:outline-none transition-transform hover:scale-110"
            title="Amber Warning"
          ></button>
          <!-- Black (Solid) -->
          <button 
            data-color="#000000" 
            class="color-dot-selector h-6 w-6 rounded-full border border-hairline bg-[#000000] focus:outline-none transition-transform hover:scale-110"
            title="Solid Black"
          ></button>
          <!-- Contrast -->
          <button 
            data-color="contrast" 
            class="color-dot-selector h-6 w-6 rounded-full border border-hairline bg-[#171717] dark:bg-[#ffffff] focus:outline-none transition-transform hover:scale-110"
            title="Contrast (Black/White)"
          ></button>
        </div>
      </div>

      <!-- Point Size & Line Thickness Sliders -->
      <div class="mt-2.5 flex flex-col gap-2 rounded-sm border border-hairline bg-canvas/30 p-2.5">
        <div class="flex flex-col gap-1">
          <div class="flex justify-between text-[9px] font-mono uppercase tracking-wider text-mute">
            <span>Point Size</span>
            <span id="point-size-value">4px</span>
          </div>
          <input 
            type="range" 
            id="point-size-slider" 
            min="2" 
            max="12" 
            value="4" 
            class="w-full h-1.5 bg-hairline rounded-lg appearance-none cursor-pointer accent-primary focus:outline-none"
          />
        </div>
        <div class="flex flex-col gap-1 mt-1">
          <div class="flex justify-between text-[9px] font-mono uppercase tracking-wider text-mute">
            <span>Line/Pen Thickness</span>
            <span id="line-width-value">2px</span>
          </div>
          <input 
            type="range" 
            id="line-width-slider" 
            min="1" 
            max="10" 
            value="2" 
            class="w-full h-1.5 bg-hairline rounded-lg appearance-none cursor-pointer accent-primary focus:outline-none"
          />
        </div>
      </div>
    </div>

    <!-- Section: Ruler / Measurements secondary utilities -->
    <div id="extra-measures-panel" class="hidden flex-col gap-2 rounded-sm border border-hairline bg-canvas/30 p-2.5">
      <span class="font-mono text-[9px] uppercase tracking-wider text-mute">Advanced Actions</span>
      <div class="flex gap-2">
        <button id="measure-midpoint-btn" class="flex-1 py-1 px-2 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft-2 text-[10px] text-ink font-medium">
          Midpoint
        </button>
        <button id="measure-angle-btn" class="flex-1 py-1 px-2 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft-2 text-[10px] text-ink font-medium">
          Angle (3 pts)
        </button>
      </div>
    </div>

    <!-- Section: Scale Settings & Snapping -->
    <div class="flex flex-col gap-2.5 rounded-md border border-hairline bg-canvas p-4 shadow-sm">
      <h4 class="font-sans text-[11px] font-semibold uppercase tracking-wider text-mute">3. Scale & Grid Rules</h4>
      
      <!-- Grid Snap -->
      <div class="flex items-center justify-between border-b border-hairline pb-2.5">
        <label for="snap-toggle" class="text-xs font-semibold text-ink cursor-pointer">Snap to Intersections</label>
        <div class="relative flex items-center">
          <input 
            type="checkbox" 
            id="snap-toggle" 
            class="peer sr-only cursor-pointer" 
            checked
          />
          <div class="h-5 w-9 rounded-full bg-hairline transition-colors peer-checked:bg-success peer-focus:outline-none cursor-pointer"></div>
          <div class="absolute left-0.5 top-0.5 h-4 w-4 rounded-full bg-white transition-transform peer-checked:translate-x-4 cursor-pointer"></div>
        </div>
      </div>

      <!-- Scale select -->
      <div class="flex flex-col gap-1.5 pt-1">
        <label for="scale-select" class="text-[10px] font-semibold text-body">Grid Scale (1 Major Division = )</label>
        <select 
          id="scale-select" 
          class="w-full h-8 rounded-sm border border-hairline bg-canvas text-xs px-2.5 text-ink focus:outline-none"
        >
          <option value="1">1 Unit (Default)</option>
          <option value="2">2 Units</option>
          <option value="5">5 Units</option>
          <option value="custom">Custom Scale...</option>
        </select>

        <div id="custom-scale-container" class="hidden flex-col gap-1 mt-1.5">
          <input 
            type="number" 
            id="custom-scale-input" 
            placeholder="E.g. 10" 
            value="1" 
            step="any"
            class="w-full h-8 rounded-sm border border-hairline bg-canvas text-xs px-2.5 text-ink focus:outline-none"
          />
        </div>
      </div>
    </div>

    <!-- Section: Equation Plotter -->
    <div class="flex flex-col gap-2.5 rounded-md border border-hairline bg-canvas p-4 shadow-sm">
      <div class="flex justify-between items-center">
        <h4 class="font-sans text-[11px] font-semibold uppercase tracking-wider text-mute">4. Mathematical Functions</h4>
      </div>
      <form id="equation-form" class="flex gap-2">
        <div class="relative flex-1">
          <input 
            type="text" 
            id="equation-input" 
            placeholder="Enter equation (e.g. y = x^2)" 
            required 
            class="w-full h-8 rounded-sm border border-hairline bg-canvas px-2.5 text-xs text-ink font-mono focus:outline-none focus:border-hairline-strong"
          />
        </div>
        <button 
          type="submit" 
          class="h-8 rounded-sm bg-primary px-3 text-xs font-medium text-on-primary hover:bg-primary/95 transition-colors focus:outline-none"
        >
          Plot
        </button>
      </form>

      <!-- Collapsible trigger for Math Keyboard -->
      <button 
        type="button" 
        id="toggle-keyboard-btn" 
        class="flex items-center justify-between w-full px-2.5 py-1.5 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-xs text-ink transition-colors focus:outline-none mt-1"
      >
        <div class="flex items-center gap-1.5 font-medium">
          <svg class="h-3.5 w-3.5 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h10a2 2 0 012 2v12a2 2 0 01-2 2zM9 8h.01M12 8h.01M15 8h.01" />
          </svg>
          <span>Math Keyboard / Tool Kit</span>
        </div>
        <svg id="keyboard-chevron" class="h-3 w-3 text-mute transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <!-- Math Keyboard Panel -->
      <div id="math-keyboard" class="hidden flex-col border border-hairline rounded-sm bg-canvas overflow-hidden mt-1.5 select-none transition-all duration-200">
        <!-- Tab headers -->
        <div class="flex border-b border-hairline bg-canvas-soft text-[10px] font-mono divide-x divide-hairline shrink-0">
          <button type="button" class="kb-tab-btn flex-1 py-1.5 text-center text-ink font-semibold bg-canvas focus:outline-none" data-tab="basic">Basic</button>
          <button type="button" class="kb-tab-btn flex-1 py-1.5 text-center text-mute hover:bg-canvas-soft-2 focus:outline-none" data-tab="trig">Trig</button>
          <button type="button" class="kb-tab-btn flex-1 py-1.5 text-center text-mute hover:bg-canvas-soft-2 focus:outline-none" data-tab="calc">Calculus</button>
          <button type="button" class="kb-tab-btn flex-1 py-1.5 text-center text-mute hover:bg-canvas-soft-2 focus:outline-none" data-tab="stats">Stats</button>
        </div>
        
        <!-- Tab Panes -->
        <div class="p-2 bg-canvas/90">
          <!-- 1. Basic Pane -->
          <div id="pane-basic" class="kb-pane flex flex-col gap-2">
            <div class="grid grid-cols-4 gap-1">
              <!-- Variables & Powers -->
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert="x">x</button>
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert="y">y</button>
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert="^2">a²</button>
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert="^">aᵇ</button>
              
              <!-- Brackets & Relations -->
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert="(">(</button>
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert=")">)</button>
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert="&lt;">&lt;</button>
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert="&gt;">&gt;</button>
              
              <!-- Functions & Constants -->
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert="abs()">|a|</button>
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert=",">,</button>
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert="&lt;=">&le;</button>
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert="&gt;=">&ge;</button>
              
              <button type="button" class="kb-key text-[10px] font-mono py-1 rounded-sm border border-hairline bg-canvas-soft text-mute focus:outline-none" data-action="clear">C</button>
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert="sqrt()">&radic;</button>
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert="pi">&pi;</button>
              <button type="button" class="kb-key text-xs font-mono py-1 rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-ink focus:outline-none" data-insert="e">e</button>
            </div>
            
            <!-- Numpad & Operators -->
