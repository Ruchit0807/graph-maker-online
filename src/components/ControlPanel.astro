<script>
  // Grid Paper Templates Switcher
  const gridSelectors = document.querySelectorAll('.grid-selector');

  function updateGridUI(grid: string) {
    gridSelectors.forEach(b => {
      const isTarget = b.getAttribute('data-grid') === grid;
      if (isTarget) {
        b.classList.remove('border-hairline');
        b.classList.add('border-primary');
        const span = b.querySelector('span');
        if (span) span.classList.add('font-semibold');
      } else {
        b.classList.remove('border-primary');
        b.classList.add('border-hairline');
        const span = b.querySelector('span');
        if (span) span.classList.remove('font-semibold');
      }
    });
  }

  // Set initial selected grid button based on theme on load
  const initialTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
  const initialGrid = initialTheme === 'dark' ? 'cartesian' : 'green';
  updateGridUI(initialGrid);

  window.addEventListener('gmo-update-grid-ui', (e: any) => {
    updateGridUI(e.detail.grid);
  });

  gridSelectors.forEach(btn => {
    btn.addEventListener('click', () => {
      const grid = btn.getAttribute('data-grid')!;
      updateGridUI(grid);
      // Dispatch event
      window.dispatchEvent(new CustomEvent('gmo-select-grid', { detail: { grid } }));
    });
  });

  // Tool Instruments Selector
  const toolSelectors = document.querySelectorAll('.tool-selector');
  const measuresPanel = document.getElementById('extra-measures-panel')!;

  toolSelectors.forEach(btn => {
    btn.addEventListener('click', () => {
      // Remove select style from all
      toolSelectors.forEach(b => {
        b.classList.remove('border-primary');
        b.classList.add('border-hairline');
        const span = b.querySelector('span');
        if (span) span.classList.remove('font-semibold');
      });
      // Add select style to clicked
      btn.classList.remove('border-hairline');
      btn.classList.add('border-primary');
      const span = btn.querySelector('span');
      if (span) span.classList.add('font-semibold');

      const tool = btn.getAttribute('data-tool')!;
      window.dispatchEvent(new CustomEvent('gmo-select-tool', { detail: { tool } }));

      // Toggle measurements secondary helper panel
      if (tool === 'distance') {
        measuresPanel.classList.remove('hidden');
        measuresPanel.classList.add('flex');
      } else {
        measuresPanel.classList.remove('flex');
        measuresPanel.classList.add('hidden');
      }
    });
  });

  // Point Size & Line Thickness Sliders
  const pointSizeSlider = document.getElementById('point-size-slider') as HTMLInputElement;
  const pointSizeValue = document.getElementById('point-size-value')!;
  const lineWidthSlider = document.getElementById('line-width-slider') as HTMLInputElement;
  const lineWidthValue = document.getElementById('line-width-value')!;

  pointSizeSlider.addEventListener('input', () => {
    const val = pointSizeSlider.value;
    pointSizeValue.textContent = `${val}px`;
    window.dispatchEvent(new CustomEvent('gmo-change-point-size', { detail: { size: Number(val) } }));
  });

  lineWidthSlider.addEventListener('input', () => {
    const val = lineWidthSlider.value;
    lineWidthValue.textContent = `${val}px`;
    window.dispatchEvent(new CustomEvent('gmo-change-line-width', { detail: { width: Number(val) } }));
  });

  // Toggle Show Point Coordinates listener
  const showCoordinatesToggle = document.getElementById('show-coordinates-toggle') as HTMLInputElement;
  showCoordinatesToggle.addEventListener('change', () => {
    window.dispatchEvent(new CustomEvent('gmo-toggle-show-coordinates', {
      detail: { show: showCoordinatesToggle.checked }
    }));
  });

  // Sync Show Point Coordinates from canvas top bar
  window.addEventListener('gmo-sidebar-sync-coordinates', (e: any) => {
    if (showCoordinatesToggle) {
      showCoordinatesToggle.checked = e.detail.show;
    }
  });

  // Equation Helper Toolkit / Math Keyboard Controller
  const eqInput = document.getElementById('equation-input') as HTMLInputElement;
  const toggleKeyboardBtn = document.getElementById('toggle-keyboard-btn');
  const mathKeyboard = document.getElementById('math-keyboard');
  const keyboardChevron = document.getElementById('keyboard-chevron');
  const kbEnterBtn = document.getElementById('kb-enter-btn');
  
  toggleKeyboardBtn?.addEventListener('click', () => {
    mathKeyboard?.classList.toggle('hidden');
    mathKeyboard?.classList.toggle('flex');
    keyboardChevron?.classList.toggle('rotate-180');
  });

  // Tab switching
  const tabBtns = document.querySelectorAll('.kb-tab-btn');
  const panes = document.querySelectorAll('.kb-pane');
  
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Remove active classes
      tabBtns.forEach(b => {
        b.classList.remove('bg-canvas', 'text-ink', 'font-semibold');
        b.classList.add('text-mute', 'hover:bg-canvas-soft-2');
      });
      panes.forEach(p => {
        p.classList.add('hidden');
        p.classList.remove('flex');
      });
      
      // Set active
      btn.classList.add('bg-canvas', 'text-ink', 'font-semibold');
      btn.classList.remove('text-mute', 'hover:bg-canvas-soft-2');
      
      const tabId = btn.getAttribute('data-tab')!;
      const pane = document.getElementById(`pane-${tabId}`);
      pane?.classList.remove('hidden');
      pane?.classList.add('flex');
    });
  });

  // Key clicks
  document.querySelectorAll('.kb-key').forEach(key => {
    key.addEventListener('click', (ev) => {
      ev.preventDefault();
      const insertVal = key.getAttribute('data-insert');
      const actionVal = key.getAttribute('data-action');
      
      if (insertVal) {
        insertAtCursor(eqInput, insertVal);
      } else if (actionVal) {
        handleKeyboardAction(actionVal);
      }
    });
  });

  function handleKeyboardAction(action: string) {
    const start = eqInput.selectionStart || 0;
    const end = eqInput.selectionEnd || 0;
    const val = eqInput.value;
    
    if (action === 'clear') {
      eqInput.value = '';
      eqInput.focus();
    } else if (action === 'backspace') {
      if (start === end) {
        if (start > 0) {
          eqInput.value = val.substring(0, start - 1) + val.substring(start);
          eqInput.focus();
          eqInput.setSelectionRange(start - 1, start - 1);
        }
      } else {
        eqInput.value = val.substring(0, start) + val.substring(end);
        eqInput.focus();
        eqInput.setSelectionRange(start, start);
      }
    } else if (action === 'left') {
      const newPos = Math.max(0, start - 1);
      eqInput.focus();
      eqInput.setSelectionRange(newPos, newPos);
    } else if (action === 'right') {
      const newPos = Math.min(val.length, start + 1);
      eqInput.focus();
      eqInput.setSelectionRange(newPos, newPos);
    } else if (action === 'enter') {
      equationForm.requestSubmit();
    }
  }

  kbEnterBtn?.addEventListener('click', () => {
    equationForm.requestSubmit();
  });

  function insertAtCursor(input: HTMLInputElement, text: string) {
    const start = input.selectionStart || 0;
    const end = input.selectionEnd || 0;
    const originalText = input.value;
    
    // Custom replacements for keyboard inserts
    let insertText = text;
    if (text === 'logbase()') {
      insertText = 'log(';
    }
    
    input.value = originalText.substring(0, start) + insertText + originalText.substring(end);
    input.focus();
    
    const newPos = start + insertText.length;
    if (insertText.endsWith('()')) {
      input.setSelectionRange(newPos - 1, newPos - 1);
    } else {
      input.setSelectionRange(newPos, newPos);
    }
  }

  // Listen to keyboard tool switches to mirror click state
  window.addEventListener('gmo-trigger-tool-selection', (e: any) => {
    const tool = e.detail.tool;
    const btn = document.querySelector(`[data-tool="${tool}"]`) as HTMLButtonElement;
    if (btn) btn.click();
  });

  // Extra measurements button listeners
  const midpointBtn = document.getElementById('measure-midpoint-btn')!;
  midpointBtn.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('gmo-select-tool', { detail: { tool: 'midpoint' } }));
    // highlight parent select button
    setHighlightToolBtn('distance');
  });

  const angleBtn = document.getElementById('measure-angle-btn')!;
  angleBtn.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('gmo-select-tool', { detail: { tool: 'angle' } }));
    setHighlightToolBtn('distance');
  });

  function setHighlightToolBtn(toolName: string) {
    toolSelectors.forEach(b => {
      if (b.getAttribute('data-tool') === toolName) {
        b.classList.remove('border-hairline');
        b.classList.add('border-primary');
        b.querySelector('span')?.classList.add('font-semibold');
      } else {
        b.classList.remove('border-primary');
        b.classList.add('border-hairline');
        b.querySelector('span')?.classList.remove('font-semibold');
      }
    });
  }

  // Snapping Toggle
  const snapToggle = document.getElementById('snap-toggle') as HTMLInputElement;
  snapToggle.addEventListener('change', () => {
    window.dispatchEvent(new CustomEvent('gmo-toggle-snap', { detail: { snap: snapToggle.checked } }));
  });

  // Line / Draw Color Selector
  const colorSelectors = document.querySelectorAll('.color-dot-selector');
  colorSelectors.forEach(btn => {
    btn.addEventListener('click', () => {
      // Remove outline/border-primary from all
      colorSelectors.forEach(b => {
        b.classList.remove('border-primary', 'border-2');
        b.classList.add('border', 'border-hairline');
      });
      // Add primary border to clicked
      btn.classList.remove('border', 'border-hairline');
      btn.classList.add('border-primary', 'border-2');

      const color = btn.getAttribute('data-color')!;
      window.dispatchEvent(new CustomEvent('gmo-change-draw-color', { detail: { color } }));
    });
  });

  // Grid Scale selector
  const scaleSelect = document.getElementById('scale-select') as HTMLSelectElement;
  const customScaleContainer = document.getElementById('custom-scale-container')!;
  const customScaleInput = document.getElementById('custom-scale-input') as HTMLInputElement;

  function handleScaleChange() {
    const val = scaleSelect.value;
    if (val === 'custom') {
      customScaleContainer.classList.remove('hidden');
      customScaleContainer.classList.add('flex');
      dispatchScale(customScaleInput.value);
    } else {
      customScaleContainer.classList.add('hidden');
      customScaleContainer.classList.remove('flex');
      dispatchScale(val);
    }
  }

  function dispatchScale(valStr: string) {
    window.dispatchEvent(new CustomEvent('gmo-select-scale', {
      detail: {
        scaleType: scaleSelect.value,
        customScale: valStr
      }
    }));
  }

  scaleSelect.addEventListener('change', handleScaleChange);
  customScaleInput.addEventListener('input', () => {
    dispatchScale(customScaleInput.value);
  });

  // Equation Form Submission
  const equationForm = document.getElementById('equation-form') as HTMLFormElement;
  const equationInput = document.getElementById('equation-input') as HTMLInputElement;
  const equationList = document.getElementById('equation-list')!;
  const integrationPanel = document.getElementById('integration-panel')!;
  const integrateBtn = document.getElementById('integrate-btn')!;
  const intStart = document.getElementById('integrate-start') as HTMLInputElement;
  const intEnd = document.getElementById('integrate-end') as HTMLInputElement;
  let activeEquations: string[] = [];

  equationForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const eq = equationInput.value.trim();
    if (!eq) return;

    // Pick random Vercel gradient color for each formula
    const presetColors = ['#0070f3', '#eb367f', '#7928ca', '#50e3c2', '#f5a623'];
    const col = presetColors[activeEquations.length % presetColors.length];

    window.dispatchEvent(new CustomEvent('gmo-plot-equation', {
      detail: { equation: eq, color: col }
    }));

    equationInput.value = '';
  });

  // Coordinate point addition form
  const addPtForm = document.getElementById('add-point-form') as HTMLFormElement;
  const ptXInput = document.getElementById('pt-x-input') as HTMLInputElement;
  const ptYInput = document.getElementById('pt-y-input') as HTMLInputElement;

  addPtForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const x = Number(ptXInput.value);
    const y = Number(ptYInput.value);
    
    window.dispatchEvent(new CustomEvent('gmo-import-points', {
      detail: {
        points: [{ x, y }],
        clearExisting: false
      }
    }));

    ptXInput.value = '';
    ptYInput.value = '';
  });

  // CSV File parser
  const csvFileInput = document.getElementById('csv-file-input') as HTMLInputElement;
  csvFileInput.addEventListener('change', (e) => {
    const file = csvFileInput.files?.[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = function(evt) {
      const text = evt.target?.result as string;
      const lines = text.split('\n');
      const imported: Array<{ x: number; y: number }> = [];

      lines.forEach(line => {
        const parts = line.split(/[;,]/);
        if (parts.length >= 2) {
          const x = parseFloat(parts[0].trim());
          const y = parseFloat(parts[1].trim());
          if (!isNaN(x) && !isNaN(y)) {
            imported.push({ x, y });
          }
        }
      });

      if (imported.length > 0) {
        if (confirm(`Found ${imported.length} points in CSV. Clear existing coordinates and plot?`)) {
          window.dispatchEvent(new CustomEvent('gmo-import-points', {
            detail: { points: imported, clearExisting: true }
          }));
        } else {
          window.dispatchEvent(new CustomEvent('gmo-import-points', {
            detail: { points: imported, clearExisting: false }
          }));
        }
      } else {
        alert("Could not find valid X, Y coordinate pairs in the uploaded CSV file. Make sure lines are formatted as: x_val, y_val");
      }
    };
    reader.readAsText(file);
    
    // Clear input to allow uploading the same file again
    csvFileInput.value = '';
  });

  // Listen for data updates from Canvas component to refresh list and stats
  window.addEventListener('gmo-canvas-data-updated', (e: any) => {
    const pointsList = e.detail.points || [];
    activeEquations = e.detail.equations || [];
    const stats = e.detail.stats || {};

    // 1. Update Points Table
    const tableBody = document.getElementById('points-table-body')!;
    tableBody.innerHTML = '';
    
    if (pointsList.length === 0) {
      tableBody.innerHTML = `
        <tr id="empty-table-row">
          <td colspan="4" class="px-2.5 py-4 text-center text-mute font-sans text-xs">No points plotted yet. Click on the canvas to place points.</td>
        </tr>
      `;
    } else {
      pointsList.forEach((pt: { id: string; name: string; x: number; y: number }) => {
        const tr = document.createElement('tr');
        tr.className = 'hover:bg-canvas-soft-2/50 group/row transition-colors';
        tr.innerHTML = `
          <td class="px-2.5 py-1 text-ink font-semibold">${pt.name}</td>
          <td class="px-2.5 py-1 text-body">${pt.x.toFixed(2)}</td>
          <td class="px-2.5 py-1 text-body">${pt.y.toFixed(2)}</td>
          <td class="px-2.5 py-1 text-right">
            <button class="del-pt-btn text-mute hover:text-error opacity-0 group-hover/row:opacity-100 transition-opacity focus:opacity-100 focus:outline-none" data-id="${pt.id}" title="Delete Point">
              <svg class="h-3.5 w-3.5 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-4v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </button>
          </td>
        `;
        tableBody.appendChild(tr);
      });

      // Bind event listeners to delete point buttons
      document.querySelectorAll('.del-pt-btn').forEach(btn => {
        btn.addEventListener('click', (ev) => {
          ev.stopPropagation();
          const id = btn.getAttribute('data-id')!;
          window.dispatchEvent(new CustomEvent('gmo-delete-point', { detail: { id } }));
        });
      });
    }

    // 2. Update Equations List
    equationList.innerHTML = '';
    activeEquations.forEach((eq, idx) => {
      const div = document.createElement('div');
      div.className = 'flex items-center justify-between border border-hairline bg-canvas-soft p-1.5 rounded-sm text-xs font-mono';
      div.innerHTML = `
        <div class="flex items-center gap-1.5 overflow-hidden">
          <span class="h-2 w-2 rounded-full shrink-0" style="background-color: ${presetColorForIndex(idx)}"></span>
          <span class="text-ink truncate max-w-[200px]">y = ${eq}</span>
        </div>
        <div class="flex items-center gap-1">
          <!-- Area Calculator for this Equation -->
          <button class="int-eq-btn text-success hover:underline font-sans text-[10px] font-semibold" data-idx="${idx}">Area</button>
          <!-- Delete -->
          <button class="del-eq-btn text-mute hover:text-error" data-eq="${eq}">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-4v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
          </button>
        </div>
      `;
      equationList.appendChild(div);
    });

    // Toggle integration panel based on equation presence
    if (activeEquations.length > 0) {
      integrationPanel.classList.remove('hidden');
      integrationPanel.classList.add('flex');
    } else {
      integrationPanel.classList.add('hidden');
      integrationPanel.classList.remove('flex');
    }

    // Bind event listeners to new elements in dynamic list
    document.querySelectorAll('.del-eq-btn').forEach(btn => {
      btn.addEventListener('click', (ev) => {
        const eq = btn.getAttribute('data-eq')!;
        window.dispatchEvent(new CustomEvent('gmo-delete-equation', { detail: { equation: eq } }));
      });
    });

    document.querySelectorAll('.int-eq-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = btn.getAttribute('data-idx')!;
        // Auto fill integration selector, or set active focus
        // We will target this index on integration button submit
        integrateBtn.setAttribute('data-target-idx', idx);
        
        // Visual indicator
        document.querySelectorAll('.int-eq-btn').forEach(b => b.classList.remove('underline'));
        btn.classList.add('underline');
      });
    });

    // 3. Update Statistics Values
    document.getElementById('stat-points')!.textContent = stats.pointsCount.toString();
    document.getElementById('stat-xrange')!.textContent = pointsList.length > 0 
      ? `${stats.minX.toFixed(1)} / ${stats.maxX.toFixed(1)}` 
      : '0 / 0';
    document.getElementById('stat-yrange')!.textContent = pointsList.length > 0 
      ? `${stats.minY.toFixed(1)} / ${stats.maxY.toFixed(1)}` 
      : '0 / 0';
    document.getElementById('stat-yaverage')!.textContent = stats.averageY.toFixed(2);
    document.getElementById('stat-slope')!.textContent = stats.slope.toFixed(2);
  });

  // Calculate Equation integration Area click
  integrateBtn.addEventListener('click', () => {
    const idx = integrateBtn.getAttribute('data-target-idx') || '0';
    const startX = intStart.value;
    const endX = intEnd.value;

    if (startX === '' || endX === '') {
      alert("Please provide both starting and ending X bounds to calculate the integral area.");
      return;
    }

    window.dispatchEvent(new CustomEvent('gmo-calculate-equation-area', {
      detail: {
        equationIndex: Number(idx),
        startX: Number(startX),
        endX: Number(endX)
      }
    }));
  });

  function presetColorForIndex(idx: number) {
    const presetColors = ['#0070f3', '#eb367f', '#7928ca', '#50e3c2', '#f5a623'];
    return presetColors[idx % presetColors.length];
  }
</script>
