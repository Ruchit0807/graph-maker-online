---
---
<footer class="w-full border-t border-hairline bg-canvas transition-colors duration-150 ease-in-out print:hidden">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-4 sm:grid-cols-2">
      <!-- Brand & Description -->
      <div class="space-y-4 md:col-span-1 col-span-full">
        <a href="/" class="flex items-center gap-2.5 group focus:outline-none shrink-0">
          <img src="/icon.png" alt="Graph Maker Online Logo" class="h-6 w-6 rounded-xs object-contain transition-transform duration-200 group-hover:scale-105" />
          <span class="font-sans text-sm font-semibold tracking-tight text-ink">Graph Maker Online</span>
        </a>
        <p class="text-xs text-body leading-relaxed max-w-xs">
          Free online graph plotter and equation sketcher. Create mathematical plots, functions, and coordinate data tables on green graph paper instantly.
        </p>
      </div>

      <!-- Column 1: Product Features -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-mute">Features</h3>
        <ul role="list" class="mt-4 space-y-2">
          <li>
            <a href="/#paper-styles" class="text-xs text-body hover:text-ink transition-colors">Graph Paper Styles</a>
          </li>
          <li>
            <a href="/#graph-plotter" class="text-xs text-body hover:text-ink transition-colors">Coordinate Plotter</a>
          </li>
          <li>
            <a href="/#function-plotter" class="text-xs text-body hover:text-ink transition-colors">Function Plotter</a>
          </li>
          <li>
            <a href="/#area-calculator" class="text-xs text-body hover:text-ink transition-colors">Area Calculator</a>
          </li>
        </ul>
      </div>

      <!-- Column 2: Information & Support -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-mute">Company</h3>
        <ul role="list" class="mt-4 space-y-2">
          <li>
            <a href="/about" class="text-xs text-body hover:text-ink transition-colors">About Us</a>
          </li>
          <li>
            <a href="/contact" class="text-xs text-body hover:text-ink transition-colors">Contact Us</a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Legal stuff -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-mute">Legal</h3>
        <ul role="list" class="mt-4 space-y-2">
          <li>
            <a href="/privacy" class="text-xs text-body hover:text-ink transition-colors">Privacy Policy</a>
          </li>
          <li>
            <a href="/terms" class="text-xs text-body hover:text-ink transition-colors">Terms & Conditions</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright Area -->
    <div class="mt-12 border-t border-hairline pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-[10px] text-mute font-mono uppercase tracking-wider">
        &copy; {new Date().getFullYear()} Graph Maker Online. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <a href="/" class="text-[10px] font-medium text-mute hover:text-ink transition-colors">Editor</a>
        <span class="h-3 w-px bg-hairline"></span>
        <a href="/about" class="text-[10px] font-medium text-mute hover:text-ink transition-colors">About</a>
        <span class="h-3 w-px bg-hairline"></span>
        <a href="/contact" class="text-[10px] font-medium text-mute hover:text-ink transition-colors">Contact</a>
      </div>
    </div>
  </div>
</footer>
