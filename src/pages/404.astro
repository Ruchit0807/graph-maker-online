---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Page Not Found (404) – Graph Maker Online"
  description="The coordinates you requested do not exist on this grid. Return to the Graph Maker Online editor to plot functions, coordinates, and lines."
>
  <div class="flex flex-col min-h-screen bg-canvas-soft text-ink transition-colors duration-150">
    <Header />

    <main class="flex-1 flex flex-col items-center justify-center py-16 sm:py-24 px-4 max-w-4xl mx-auto w-full text-center relative overflow-hidden">
      <!-- Grid backdrop decoration -->
      <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05] bg-radial-[circle_at_1px_1px] bg-[size:20px_20px] bg-[#171717] dark:bg-[#ffffff] pointer-events-none"></div>

      <!-- Theme/Math Thematic Illustration -->
      <div class="relative w-full max-w-md h-48 border border-hairline bg-canvas rounded-md shadow-xs p-6 mb-8 flex items-center justify-center overflow-hidden">
        <!-- SVG Grid & Axes -->
        <svg class="absolute inset-0 w-full h-full text-hairline" xmlns="http://www.w3.org/2000/svg">
          <!-- Grid lines -->
          <line x1="0" y1="50%" x2="100%" y2="50%" stroke="currentColor" stroke-width="1.5" />
          <line x1="50%" y1="0" x2="50%" y2="100%" stroke="currentColor" stroke-width="1.5" />
          <line x1="25%" y1="0" x2="25%" y2="100%" stroke="currentColor" stroke-dasharray="2 2" />
          <line x1="75%" y1="0" x2="75%" y2="100%" stroke="currentColor" stroke-dasharray="2 2" />
          <line x1="0" y1="25%" x2="100%" y2="25%" stroke="currentColor" stroke-dasharray="2 2" />
          <line x1="0" y1="75%" x2="100%" y2="75%" stroke="currentColor" stroke-dasharray="2 2" />
          
          <!-- 404 Plotted Point Projection Lines -->
          <line x1="50%" y1="25%" x2="75%" y2="25%" stroke="#ff0080" stroke-width="1" stroke-dasharray="3 3" />
          <line x1="75%" y1="50%" x2="75%" y2="25%" stroke="#ff0080" stroke-width="1" stroke-dasharray="3 3" />
        </svg>

        <!-- Thematic 404 Text & Point -->
        <div class="relative z-10 flex flex-col items-center">
          <div class="relative">
            <!-- Neon Pulsing Point -->
            <div class="absolute -top-1.5 -left-1.5 h-3.5 w-3.5 rounded-full bg-highlight-pink animate-ping opacity-75"></div>
            <div class="absolute -top-0.5 -left-0.5 h-1.5 w-1.5 rounded-full bg-highlight-pink"></div>
          </div>
          <!-- Huge Coordinate Tag -->
          <span class="font-mono text-xs text-highlight-pink mt-3 bg-highlight-pink/10 px-2 py-0.5 rounded-sm border border-highlight-pink/20">
            P = (404, 404)
          </span>
          <span class="text-[9px] font-mono uppercase tracking-wider text-mute mt-1.5">
            Plot Not Found
          </span>
        </div>
      </div>

      <!-- Text Section -->
      <div class="max-w-md mx-auto space-y-4">
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight bg-gradient-to-r from-violet via-highlight-pink to-link-blue bg-clip-text text-transparent">
          404 Error
        </h1>
        <h2 class="text-xl sm:text-2xl font-bold text-ink">
          Coordinates Out of Bounds
        </h2>
        <p class="text-xs sm:text-sm text-body leading-relaxed max-w-sm mx-auto">
          The mathematical path or function you requested does not exist on this graph canvas. Let's redirect you back to active coordinates.
        </p>
      </div>

      <!-- Action Buttons -->
      <div class="mt-8 flex flex-wrap gap-3 items-center justify-center">
        <a 
          href="/" 
          class="h-9 inline-flex items-center justify-center rounded-sm bg-primary px-5 text-xs font-semibold text-on-primary hover:bg-primary/95 transition-colors shadow-xs"
        >
          Return to Graph Editor
        </a>
        <a 
          href="/contact" 
          class="h-9 inline-flex items-center justify-center rounded-sm border border-hairline bg-canvas px-5 text-xs font-medium text-ink hover:bg-canvas-soft-2 transition-colors"
        >
          Report Dead Link
        </a>
      </div>
    </main>

    <Footer />
  </div>
</Layout>
