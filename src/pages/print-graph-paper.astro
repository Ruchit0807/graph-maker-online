<!-- Core Application Client Script -->
<script is:inline>
  // Global holder to check libraries loading
  window.addEventListener('load', () => {
    // Dynamic jsPDF loader helper
    async function getJsPDF() {
      if (window.jspdf) return window.jspdf.jsPDF;
      await new Promise((resolve, reject) => {
        const script = document.createElement('script');
        script.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
        script.onload = () => resolve(null);
        script.onerror = () => reject(new Error('Failed to load jsPDF'));
        document.head.appendChild(script);
      });
      // @ts-ignore
      return window.jspdf.jsPDF;
    }

    // DOM Elements
    const paperCanvas = document.getElementById('paper-canvas');
    const paperCtx = paperCanvas.getContext('2d');
    
    const drawingCanvas = document.getElementById('drawing-canvas');
    const drawCtx = drawingCanvas.getContext('2d');

    const shadowWrapper = document.getElementById('paper-shadow-wrapper');
    const printVectorContainer = document.getElementById('print-vector-container');
    
    // HUD Elements
    const zoomInHUD = document.getElementById('view-zoom-in');
    const zoomOutHUD = document.getElementById('view-zoom-out');
    const resetHUD = document.getElementById('view-reset');
    const zoomHUDTxt = document.getElementById('zoom-hud-txt');
    const textPopup = document.getElementById('text-editor-popup');
    const textInput = document.getElementById('text-editor-input');
    const textCancel = document.getElementById('text-editor-cancel');
    const textOK = document.getElementById('text-editor-ok');

    // Inputs & Sidebar controls
    const sizeSelect = document.getElementById('paper-size');
    const customDims = document.getElementById('custom-dims');
    const customWInput = document.getElementById('custom-w');
    const customHInput = document.getElementById('custom-h');
    
    const orientPortrait = document.getElementById('orient-portrait');
    const orientLandscape = document.getElementById('orient-landscape');
    
    const unitSelect = document.getElementById('spacing-unit');
    const spacingSelect = document.getElementById('grid-spacing-preset');
    const customSpacingContainer = document.getElementById('custom-spacing-container');
    const customSpacingInput = document.getElementById('custom-spacing-input');
    const majorSelect = document.getElementById('major-interval');
    
    const themeSelect = document.getElementById('theme-preset');
    const customColorsWrapper = document.getElementById('custom-colors-wrapper');
    const colorBG = document.getElementById('color-bg');
    const colorMinor = document.getElementById('color-minor');
    const colorMajor = document.getElementById('color-major');
    const opacitySlider = document.getElementById('grid-opacity-slider');
    const thicknessSlider = document.getElementById('grid-thickness-slider');
    
    const marginSelect = document.getElementById('margin-type');
    const customMarginsFields = document.getElementById('custom-margins-fields');
    const mTopInput = document.getElementById('m-top');
    const mBottomInput = document.getElementById('m-bottom');
    const mLeftInput = document.getElementById('m-left');
    const mRightInput = document.getElementById('m-right');
    
    const checkPrintGuides = document.getElementById('check-print-guides');
    const checkCropMarks = document.getElementById('check-crop-marks');

    const brushColorInput = document.getElementById('draw-color');
    const brushSlider = document.getElementById('brush-size-slider');

    const sidebarBackdrop = document.getElementById('sidebar-backdrop');
    
    // Actions
    const btnPrint = document.getElementById('main-print-btn');
    const btnPNG = document.getElementById('export-png');
    const btnSVG = document.getElementById('export-svg');
    const btnPDFRaster = document.getElementById('export-pdf-raster');
    const btnPDFVector = document.getElementById('export-pdf-vector');
    const btnCopyURL = document.getElementById('copy-url-btn');

    const btnUndo = document.getElementById('draw-undo');
    const btnRedo = document.getElementById('draw-redo');
    const btnClear = document.getElementById('draw-clear');

    // Toolbar elements
    const toolbar = document.getElementById('drawing-toolbar');
    const toggleToolbarBtn = document.getElementById('toggle-toolbar-orient');

    // Geometry Definitions
    const sizesMm = {
      A5: { w: 148, h: 210 },
      A4: { w: 210, h: 297 },
      A3: { w: 297, h: 420 },
      A2: { w: 420, h: 594 },
      letter: { w: 215.9, h: 279.4 },
      legal: { w: 215.9, h: 355.6 },
      tabloid: { w: 279.4, h: 431.8 }
    };

    const themes = {
      classic: { bg: '#ffffff', minor: '#e2e8f0', major: '#94a3b8' },
      green: { bg: '#fafdfa', minor: '#c2ebd0', major: '#4fa368' },
      blueprint: { bg: '#0b2447', minor: '#1d5c96', major: '#a5f3fc' },
      lightgray: { bg: '#fbfbfb', minor: '#e5e5e5', major: '#737373' },
      dark: { bg: '#0e0e11', minor: '#27272a', major: '#52525b' }
    };

    let settings = {
      gridType: 'green',
      paperSize: 'A4',
      customWidth: 210,
      customHeight: 297,
      orientation: 'portrait',
      spacingUnit: 'mm',
      gridSpacing: 5.0,
      majorInterval: 5,
      theme: 'green',
      backgroundColor: '#fafdfa',
      minorColor: '#c2ebd0',
      majorColor: '#4fa368',
      gridOpacity: 0.85,
      gridThickness: 0.35,
      marginType: 'auto',
      marginTop: 10,
      marginBottom: 10,
      marginLeft: 10,
      marginRight: 10,
      showPrintGuides: true,
      showCropMarks: false,
      activeTool: 'move',
      drawColor: '#000000',
      drawSize: 1.0
    };

    let viewportState = {
      zoom: 1.0,
      panX: 0,
      panY: 0
    };

    let shapes = [];
    let shapesRedoStack = [];

    let isInteracting = false;
    let lastX = 0;
    let lastY = 0;
    let textPopupPosition = { x: 0, y: 0 };
    let currentStrokePoints = [];

    // Touch variables for mobile
    let lastTouchDist = 0;
    let touchStartX = 0;
    let touchStartY = 0;
    let touchStartTime = 0;
    let touchCanceled = false;

    const RENDER_DPI = 150;
    const MM_TO_INCH = 25.4;
    const pixelsPerMm = RENDER_DPI / MM_TO_INCH;

    function init() {
      loadFromUrl();
      syncSidebarUi();
      applyThemeColors();
      updatePaperSize();
      fitToContainer();
      drawPaper();
      setupEventListeners();
    }

    function syncSidebarUi() {
      document.querySelectorAll('.grid-selector').forEach(btn => {
        const type = btn.getAttribute('data-type');
        if (type === settings.gridType) {
          btn.classList.add('border-primary', 'bg-canvas-soft-2');
          btn.classList.remove('border-hairline');
        } else {
          btn.classList.remove('border-primary', 'bg-canvas-soft-2');
          btn.classList.add('border-hairline');
        }
      });

      sizeSelect.value = settings.paperSize;
      if (settings.paperSize === 'custom') {
        customDims.classList.remove('hidden');
        customWInput.value = settings.customWidth.toString();
        customHInput.value = settings.customHeight.toString();
      } else {
        customDims.classList.add('hidden');
      }

      if (settings.orientation === 'portrait') {
        orientPortrait.classList.add('border-primary', 'font-semibold');
        orientPortrait.classList.remove('border-hairline', 'font-medium');
        orientLandscape.classList.remove('border-primary', 'font-semibold');
        orientLandscape.classList.add('border-hairline', 'font-medium');
      } else {
        orientLandscape.classList.add('border-primary', 'font-semibold');
        orientLandscape.classList.remove('border-hairline', 'font-medium');
        orientPortrait.classList.remove('border-primary', 'font-semibold');
        orientPortrait.classList.add('border-hairline', 'font-medium');
      }

      unitSelect.value = settings.spacingUnit;
      
      let spacingVal = settings.gridSpacing;
      if (settings.spacingUnit === 'cm') spacingVal = settings.gridSpacing / 10;
      if (settings.spacingUnit === 'in') spacingVal = settings.gridSpacing / 25.4;

      const presetOptions = Array.from(spacingSelect.options).map(o => o.value);
      const closestPreset = presetOptions.find(val => Math.abs(Number(val) - spacingVal) < 1e-4);
      
      if (closestPreset && closestPreset !== 'custom') {
        spacingSelect.value = closestPreset;
        customSpacingContainer.classList.add('hidden');
      } else {
        spacingSelect.value = 'custom';
        customSpacingContainer.classList.remove('hidden');
        customSpacingInput.value = spacingVal.toString();
      }

      majorSelect.value = settings.majorInterval.toString();
      themeSelect.value = settings.theme;
      if (settings.theme === 'custom') {
        customColorsWrapper.classList.remove('hidden');
      } else {
        customColorsWrapper.classList.add('hidden');
      }
      colorBG.value = settings.backgroundColor;
      colorMinor.value = settings.minorColor;
      colorMajor.value = settings.majorColor;
      
      opacitySlider.value = Math.round(settings.gridOpacity * 100).toString();
      document.getElementById('opacity-val-txt').textContent = `${Math.round(settings.gridOpacity * 100)}%`;
      
      thicknessSlider.value = Math.round(settings.gridThickness * 100).toString();
      document.getElementById('thickness-val-txt').textContent = `${settings.gridThickness.toFixed(2)}mm`;

      marginSelect.value = settings.marginType;
      if (settings.marginType === 'custom') {
        customMarginsFields.classList.remove('hidden');
        mTopInput.value = settings.marginTop.toString();
        mBottomInput.value = settings.marginBottom.toString();
        mLeftInput.value = settings.marginLeft.toString();
        mRightInput.value = settings.marginRight.toString();
      } else {
        customMarginsFields.classList.add('hidden');
      }

      checkPrintGuides.checked = settings.showPrintGuides;
      checkCropMarks.checked = settings.showCropMarks;

      brushColorInput.value = settings.drawColor;
      brushSlider.value = Math.round(settings.drawSize * 10).toString();
      document.getElementById('brush-size-val').textContent = `${settings.drawSize.toFixed(1)}mm`;

      document.querySelectorAll('.draw-tool-btn').forEach(btn => {
        const tool = btn.getAttribute('data-tool');
        if (tool === settings.activeTool) {
          btn.classList.add('active', 'border-primary', 'bg-canvas-soft-2');
          btn.classList.remove('border-hairline');
        } else {
          btn.classList.remove('active', 'border-primary', 'bg-canvas-soft-2');
          btn.classList.add('border-hairline');
        }
      });

      updateUndoRedoButtons();
    }

    function applyThemeColors() {
      if (settings.theme === 'custom') return;
      const colors = themes[settings.theme];
      if (colors) {
        settings.backgroundColor = colors.bg;
        settings.minorColor = colors.minor;
        settings.majorColor = colors.major;
      }
    }

    function updatePaperSize() {
      let w = 210;
      let h = 297;
      
      if (settings.paperSize === 'custom') {
        w = settings.customWidth;
        h = settings.customHeight;
      } else {
        const def = sizesMm[settings.paperSize];
        if (def) {
          w = def.w;
          h = def.h;
        }
      }

      if (settings.orientation === 'landscape') {
        const tmp = w;
        w = h;
        h = tmp;
      }

      const widthPx = Math.round(w * pixelsPerMm);
      const heightPx = Math.round(h * pixelsPerMm);

      paperCanvas.width = widthPx;
      paperCanvas.height = heightPx;
      drawingCanvas.width = widthPx;
      drawingCanvas.height = heightPx;

      const screenScale = 2.0;
      shadowWrapper.style.width = `${Math.round(w * screenScale)}px`;
      shadowWrapper.style.height = `${Math.round(h * screenScale)}px`;

      paperCtx.resetTransform();
      paperCtx.scale(pixelsPerMm, pixelsPerMm);
      drawCtx.resetTransform();
      drawCtx.scale(pixelsPerMm, pixelsPerMm);
    }

    function fitToContainer() {
      const previewContainer = shadowWrapper.parentElement;
      const pad = 64;
      const availW = previewContainer.clientWidth - pad;
      const availH = previewContainer.clientHeight - pad;

      const paperW = parseFloat(shadowWrapper.style.width);
      const paperH = parseFloat(shadowWrapper.style.height);

      const scaleX = availW / paperW;
      const scaleY = availH / paperH;
      const finalZoom = Math.min(scaleX, scaleY, 1.5);

      viewportState.zoom = finalZoom;
      viewportState.panX = 0;
      viewportState.panY = 0;

      applyViewportTransform();
    }

    function applyViewportTransform() {
      shadowWrapper.style.transform = `translate(${viewportState.panX}px, ${viewportState.panY}px) scale(${viewportState.zoom})`;
      zoomHUDTxt.textContent = `${Math.round(viewportState.zoom * 100)}%`;
    }

    function drawPaper() {
      drawGrid();
      drawOverlayShapes();
    }

    function drawGrid() {
      let W = paperCanvas.width / pixelsPerMm;
      let H = paperCanvas.height / pixelsPerMm;

      let mL = settings.marginType === 'auto' ? 10 : settings.marginLeft;
      let mR = settings.marginType === 'auto' ? 10 : settings.marginRight;
      let mT = settings.marginType === 'auto' ? 10 : settings.marginTop;
      let mB = settings.marginType === 'auto' ? 10 : settings.marginBottom;

      const left = mL;
      const right = W - mR;
      const top = mT;
      const bottom = H - mB;

      paperCtx.clearRect(0, 0, W, H);
      paperCtx.fillStyle = settings.backgroundColor;
      paperCtx.fillRect(0, 0, W, H);

      paperCtx.save();
      paperCtx.beginPath();
      paperCtx.rect(left, top, right - left, bottom - top);
      paperCtx.clip();

      paperCtx.globalAlpha = settings.gridOpacity;
      paperCtx.lineCap = 'round';
      paperCtx.lineJoin = 'round';

      const spacing = settings.gridSpacing;
      const major = settings.majorInterval;

      if (settings.gridType === 'square' || settings.gridType === 'green' || settings.gridType === 'cartesian') {
        let col = 0;
        for (let x = left; x <= right + 0.01; x += spacing) {
          const isMajor = major > 0 && col % major === 0;
          paperCtx.strokeStyle = isMajor ? settings.majorColor : settings.minorColor;
          paperCtx.lineWidth = isMajor ? settings.gridThickness : settings.gridThickness / 2;
          
          paperCtx.beginPath();
          paperCtx.moveTo(x, top);
          paperCtx.lineTo(x, bottom);
          paperCtx.stroke();
          col++;
        }

        let row = 0;
        for (let y = top; y <= bottom + 0.01; y += spacing) {
          const isMajor = major > 0 && row % major === 0;
          paperCtx.strokeStyle = isMajor ? settings.majorColor : settings.minorColor;
          paperCtx.lineWidth = isMajor ? settings.gridThickness : settings.gridThickness / 2;
          
          paperCtx.beginPath();
          paperCtx.moveTo(left, y);
          paperCtx.lineTo(right, y);
          paperCtx.stroke();
          row++;
        }

        if (settings.gridType === 'cartesian') {
          const cx = left + (right - left) / 2;
          const cy = top + (bottom - top) / 2;

          paperCtx.strokeStyle = settings.majorColor;
          paperCtx.lineWidth = settings.gridThickness * 1.5;

          paperCtx.beginPath();
          paperCtx.moveTo(left, cy);
          paperCtx.lineTo(right, cy);
          paperCtx.stroke();

          paperCtx.beginPath();
          paperCtx.moveTo(cx, top);
          paperCtx.lineTo(cx, bottom);
          paperCtx.stroke();

          paperCtx.fillStyle = settings.majorColor;
          paperCtx.font = '2.5px sans-serif';
          paperCtx.textAlign = 'center';
          
          let labelIndex = 0;
          for (let x = cx + spacing; x <= right; x += spacing) {
            labelIndex++;
            if (labelIndex % 2 === 0) paperCtx.fillText(labelIndex.toString(), x, cy + 3.5);
          }
          labelIndex = 0;
          for (let x = cx - spacing; x >= left; x -= spacing) {
            labelIndex++;
            if (labelIndex % 2 === 0) paperCtx.fillText(`-${labelIndex}`, x, cy + 3.5);
          }

          paperCtx.textAlign = 'right';
          labelIndex = 0;
          for (let y = cy - spacing; y >= top; y -= spacing) {
            labelIndex++;
            if (labelIndex % 2 === 0) paperCtx.fillText(labelIndex.toString(), cx - 1.5, y + 0.8);
          }
          labelIndex = 0;
          for (let y = cy + spacing; y <= bottom; y += spacing) {
            labelIndex++;
            if (labelIndex % 2 === 0) paperCtx.fillText(`-${labelIndex}`, cx - 1.5, y + 0.8);
          }
        }
      } else if (settings.gridType === 'dot') {
        paperCtx.fillStyle = settings.majorColor;
        const dotRadius = Math.max(0.3, settings.gridThickness);
        for (let x = left; x <= right + 0.01; x += spacing) {
          for (let y = top; y <= bottom + 0.01; y += spacing) {
            paperCtx.beginPath();
            paperCtx.arc(x, y, dotRadius, 0, 2 * Math.PI);
            paperCtx.fill();
          }
        }
      } else if (settings.gridType === 'isometric') {
        const dy = spacing * Math.sqrt(3) / 2;
        paperCtx.strokeStyle = settings.minorColor;
        paperCtx.lineWidth = settings.gridThickness / 2;

        for (let x = left; x <= right + 0.01; x += spacing) {
          paperCtx.beginPath();
          paperCtx.moveTo(x, top);
          paperCtx.lineTo(x, bottom);
          paperCtx.stroke();
        }

        const stepC = spacing * Math.sqrt(3);
        const minC = top - 0.57735 * right;
        const maxC = bottom - 0.57735 * left;
        for (let c = minC; c <= maxC; c += stepC) {
          paperCtx.beginPath();
          paperCtx.moveTo(left, 0.57735 * left + c);
          paperCtx.lineTo(right, 0.57735 * right + c);
          paperCtx.stroke();
        }

        const minC2 = top + 0.57735 * left;
        const maxC2 = bottom + 0.57735 * right;
        for (let c = minC2; c <= maxC2; c += stepC) {
          paperCtx.beginPath();
          paperCtx.moveTo(left, -0.57735 * left + c);
          paperCtx.lineTo(right, -0.57735 * right + c);
          paperCtx.stroke();
        }
      } else if (settings.gridType === 'polar') {
        const cx = left + (right - left) / 2;
        const cy = top + (bottom - top) / 2;
        const maxRadius = Math.sqrt((right - left) ** 2 + (bottom - top) ** 2) / 2;

        paperCtx.strokeStyle = settings.minorColor;
        paperCtx.lineWidth = settings.gridThickness / 2;

        for (let r = spacing; r <= maxRadius; r += spacing) {
          paperCtx.beginPath();
          paperCtx.arc(cx, cy, r, 0, 2 * Math.PI);
          paperCtx.stroke();
        }

        for (let angle = 0; angle < 360; angle += 15) {
          const rad = (angle * Math.PI) / 180;
          const x2 = cx + maxRadius * Math.cos(rad);
          const y2 = cy + maxRadius * Math.sin(rad);
          
          paperCtx.beginPath();
          paperCtx.moveTo(cx, cy);
          paperCtx.lineTo(x2, y2);
          paperCtx.stroke();
        }
      } else if (settings.gridType === 'loglog' || settings.gridType === 'semilog') {
        const numDecadesX = settings.gridType === 'loglog' ? 3 : 5;
        const numDecadesY = 4;
        const decWidth = (right - left) / numDecadesX;
        const decHeight = (bottom - top) / numDecadesY;

        if (settings.gridType === 'loglog') {
          for (let d = 0; d < numDecadesX; d++) {
            const dStart = left + d * decWidth;
            paperCtx.strokeStyle = settings.majorColor;
            paperCtx.lineWidth = settings.gridThickness;
            paperCtx.beginPath();
            paperCtx.moveTo(dStart, top);
            paperCtx.lineTo(dStart, bottom);
            paperCtx.stroke();

            paperCtx.strokeStyle = settings.minorColor;
            paperCtx.lineWidth = settings.gridThickness / 2;
            for (let k = 2; k <= 9; k++) {
              const x = dStart + Math.log10(k) * decWidth;
              paperCtx.beginPath();
              paperCtx.moveTo(x, top);
              paperCtx.lineTo(x, bottom);
              paperCtx.stroke();
            }
          }
          paperCtx.strokeStyle = settings.majorColor;
          paperCtx.lineWidth = settings.gridThickness;
          paperCtx.beginPath();
          paperCtx.moveTo(right, top);
          paperCtx.lineTo(right, bottom);
          paperCtx.stroke();
        } else {
          for (let x = left; x <= right + 0.01; x += spacing) {
            paperCtx.strokeStyle = settings.minorColor;
            paperCtx.lineWidth = settings.gridThickness / 2;
            paperCtx.beginPath();
            paperCtx.moveTo(x, top);
            paperCtx.lineTo(x, bottom);
            paperCtx.stroke();
          }
        }

        for (let d = 0; d < numDecadesY; d++) {
          const dStart = bottom - d * decHeight;
          paperCtx.strokeStyle = settings.majorColor;
          paperCtx.lineWidth = settings.gridThickness;
          paperCtx.beginPath();
          paperCtx.moveTo(left, dStart);
          paperCtx.lineTo(right, dStart);
          paperCtx.stroke();

          paperCtx.strokeStyle = settings.minorColor;
          paperCtx.lineWidth = settings.gridThickness / 2;
          for (let k = 2; k <= 9; k++) {
            const y = dStart - Math.log10(k) * decHeight;
            paperCtx.beginPath();
            paperCtx.moveTo(left, y);
            paperCtx.lineTo(right, y);
            paperCtx.stroke();
          }
        }
        paperCtx.strokeStyle = settings.majorColor;
        paperCtx.lineWidth = settings.gridThickness;
        paperCtx.beginPath();
        paperCtx.moveTo(left, top);
        paperCtx.lineTo(right, top);
        paperCtx.stroke();
      } else if (settings.gridType === 'hexagonal') {
        const r = spacing;
        const h = r * Math.sqrt(3);

        paperCtx.strokeStyle = settings.minorColor;
        paperCtx.lineWidth = settings.gridThickness / 2;

        const cols = Math.ceil((right - left) / (r * 1.5)) + 1;
        const rows = Math.ceil((bottom - top) / h) + 1;

        for (let col = -1; col < cols; col++) {
          for (let row = -1; row < rows; row++) {
            const cx = left + col * r * 1.5;
            const cy = top + row * h + (col % 2 === 0 ? 0 : h / 2);

            paperCtx.beginPath();
            for (let i = 0; i < 6; i++) {
              const angle = (i * Math.PI) / 3;
              const x = cx + r * Math.cos(angle);
              const y = cy + r * Math.sin(angle);
              if (i === 0) paperCtx.moveTo(x, y);
              else paperCtx.lineTo(x, y);
            }
            paperCtx.closePath();
            paperCtx.stroke();
          }
        }
      } else if (settings.gridType === 'triangular') {
        const dy = spacing * Math.sqrt(3) / 2;
        paperCtx.strokeStyle = settings.minorColor;
        paperCtx.lineWidth = settings.gridThickness / 2;

        for (let y = top; y <= bottom + 0.01; y += dy) {
          paperCtx.beginPath();
          paperCtx.moveTo(left, y);
          paperCtx.lineTo(right, y);
          paperCtx.stroke();
        }

        const stepC = spacing;
        const minC = top - 1.73205 * right;
        const maxC = bottom - 1.73205 * left;
        for (let c = minC; c <= maxC; c += stepC) {
          paperCtx.beginPath();
          paperCtx.moveTo(left, 1.73205 * left + c);
          paperCtx.lineTo(right, 1.73205 * right + c);
          paperCtx.stroke();
        }

        const minC2 = top + 1.73205 * left;
        const maxC2 = bottom + 1.73205 * right;
        for (let c = minC2; c <= maxC2; c += stepC) {
          paperCtx.beginPath();
          paperCtx.moveTo(left, -1.73205 * left + c);
          paperCtx.lineTo(right, -1.73205 * right + c);
          paperCtx.stroke();
        }
      }

      paperCtx.restore();

      if (settings.showPrintGuides) {
        paperCtx.strokeStyle = settings.majorColor;
        paperCtx.lineWidth = 0.25;
        paperCtx.setLineDash([2, 2]);
        paperCtx.beginPath();
        paperCtx.rect(left, top, right - left, bottom - top);
        paperCtx.stroke();
        paperCtx.setLineDash([]);
      }

      if (settings.showCropMarks) {
        paperCtx.strokeStyle = '#000000';
        paperCtx.lineWidth = 0.25;
        const size = 5;

        paperCtx.beginPath();
        paperCtx.moveTo(0, top); paperCtx.lineTo(size, top);
        paperCtx.moveTo(left, 0); paperCtx.lineTo(left, size);
        paperCtx.stroke();

        paperCtx.beginPath();
        paperCtx.moveTo(W, top); paperCtx.lineTo(W - size, top);
        paperCtx.moveTo(right, 0); paperCtx.lineTo(right, size);
        paperCtx.stroke();

        paperCtx.beginPath();
        paperCtx.moveTo(0, bottom); paperCtx.lineTo(size, bottom);
        paperCtx.moveTo(left, H); paperCtx.lineTo(left, H - size);
        paperCtx.stroke();

        paperCtx.beginPath();
        paperCtx.moveTo(W, bottom); paperCtx.lineTo(W - size, bottom);
        paperCtx.moveTo(right, H); paperCtx.lineTo(right, H - size);
        paperCtx.stroke();
      }

      paperCtx.globalAlpha = 1.0;
    }

    function drawOverlayShapes() {
      const W = drawingCanvas.width / pixelsPerMm;
      const H = drawingCanvas.height / pixelsPerMm;
      
      drawCtx.clearRect(0, 0, W, H);

      shapes.forEach(shape => {
        drawSingleShape(drawCtx, shape);
      });

      if (isInteracting && currentStrokePoints.length > 0) {
        const activeShape = {
          type: settings.activeTool,
          points: currentStrokePoints,
          color: settings.drawColor,
          width: settings.drawSize
        };
        drawSingleShape(drawCtx, activeShape);
      }
    }

    function drawSingleShape(ctx, shape) {
      if (shape.type === 'eraser') {
        ctx.save();
        ctx.globalCompositeOperation = 'destination-out';
        ctx.strokeStyle = 'rgba(0,0,0,1)';
        ctx.lineWidth = shape.width;
        ctx.beginPath();
        if (shape.points.length > 0) {
          ctx.moveTo(shape.points[0].x, shape.points[0].y);
          for (let i = 1; i < shape.points.length; i++) {
            ctx.lineTo(shape.points[i].x, shape.points[i].y);
          }
        }
        ctx.stroke();
        ctx.restore();
      } else if (shape.type === 'pencil' || shape.type === 'pen') {
        if (shape.points.length < 1) return;
        ctx.beginPath();
        ctx.moveTo(shape.points[0].x, shape.points[0].y);
        for (let i = 1; i < shape.points.length; i++) {
          ctx.lineTo(shape.points[i].x, shape.points[i].y);
        }
        ctx.stroke();
      } else if (shape.type === 'line') {
        if (shape.points.length < 2) return;
        ctx.beginPath();
        ctx.moveTo(shape.points[0].x, shape.points[0].y);
        ctx.lineTo(shape.points[1].x, shape.points[1].y);
        ctx.stroke();
      } else if (shape.type === 'arrow') {
        if (shape.points.length < 2) return;
        const p0 = shape.points[0];
        const p1 = shape.points[1];
        ctx.beginPath();
        ctx.moveTo(p0.x, p0.y);
        ctx.lineTo(p1.x, p1.y);
        ctx.stroke();

        const angle = Math.atan2(p1.y - p0.y, p1.x - p0.x);
        const headlen = 4;
        ctx.beginPath();
        ctx.moveTo(p1.x, p1.y);
        ctx.lineTo(p1.x - headlen * Math.cos(angle - Math.PI / 6), p1.y - headlen * Math.sin(angle - Math.PI / 6));
        ctx.moveTo(p1.x, p1.y);
        ctx.lineTo(p1.x - headlen * Math.cos(angle + Math.PI / 6), p1.y - headlen * Math.sin(angle + Math.PI / 6));
        ctx.stroke();
      } else if (shape.type === 'rect') {
        if (shape.points.length < 2) return;
        const x = Math.min(shape.points[0].x, shape.points[1].x);
        const y = Math.min(shape.points[0].y, shape.points[1].y);
        const w = Math.abs(shape.points[0].x - shape.points[1].x);
        const h = Math.abs(shape.points[0].y - shape.points[1].y);
        ctx.strokeRect(x, y, w, h);
      } else if (shape.type === 'circle') {
        if (shape.points.length < 2) return;
        const r = Math.hypot(shape.points[1].x - shape.points[0].x, shape.points[1].y - shape.points[0].y);
        ctx.beginPath();
        ctx.arc(shape.points[0].x, shape.points[0].y, r, 0, 2 * Math.PI);
        ctx.stroke();
      } else if (shape.type === 'text') {
        if (shape.points.length < 1) return;
        ctx.fillStyle = shape.color;
        ctx.font = `${shape.width * 1.5}px sans-serif`;
        ctx.fillText(shape.text || '', shape.points[0].x, shape.points[0].y);
      }
    }

    function screenToPaper(clientX, clientY) {
      const rect = drawingCanvas.getBoundingClientRect();
      const scaleX = drawingCanvas.width / rect.width;
      const scaleY = drawingCanvas.height / rect.height;
      
      const px = (clientX - rect.left) * scaleX;
      const py = (clientY - rect.top) * scaleY;
      
      return {
        x: px / pixelsPerMm,
        y: py / pixelsPerMm
      };
    }

    function setupEventListeners() {
      zoomInHUD.addEventListener('click', () => {
        viewportState.zoom = Math.min(3.0, viewportState.zoom * 1.2);
        applyViewportTransform();
      });
      zoomOutHUD.addEventListener('click', () => {
        viewportState.zoom = Math.max(0.2, viewportState.zoom / 1.2);
        applyViewportTransform();
      });
      resetHUD.addEventListener('click', () => {
        fitToContainer();
      });

      window.addEventListener('resize', () => {
        fitToContainer();
      });

      document.querySelectorAll('.grid-selector').forEach(btn => {
        btn.addEventListener('click', () => {
          settings.gridType = btn.getAttribute('data-type');
          syncSidebarUi();
          drawPaper();
        });
      });

      sizeSelect.addEventListener('change', () => {
        settings.paperSize = sizeSelect.value;
        if (settings.paperSize === 'custom') {
          customDims.classList.remove('hidden');
        } else {
          customDims.classList.add('hidden');
        }
        updatePaperSize();
        fitToContainer();
        drawPaper();
      });

      customWInput.addEventListener('input', () => {
        settings.customWidth = parseFloat(customWInput.value) || 210;
        updatePaperSize();
        fitToContainer();
        drawPaper();
      });

      customHInput.addEventListener('input', () => {
        settings.customHeight = parseFloat(customHInput.value) || 297;
        updatePaperSize();
        fitToContainer();
        drawPaper();
      });

      orientPortrait.addEventListener('click', () => {
        settings.orientation = 'portrait';
        syncSidebarUi();
        updatePaperSize();
        fitToContainer();
        drawPaper();
      });

      orientLandscape.addEventListener('click', () => {
        settings.orientation = 'landscape';
        syncSidebarUi();
        updatePaperSize();
        fitToContainer();
        drawPaper();
      });

      unitSelect.addEventListener('change', () => {
        settings.spacingUnit = unitSelect.value;
        updateSpacing();
      });

      spacingSelect.addEventListener('change', () => {
        updateSpacing();
      });

      customSpacingInput.addEventListener('input', () => {
        updateSpacing();
      });

      majorSelect.addEventListener('change', () => {
        settings.majorInterval = parseInt(majorSelect.value);
        drawPaper();
      });

      themeSelect.addEventListener('change', () => {
        settings.theme = themeSelect.value;
        applyThemeColors();
        syncSidebarUi();
        drawPaper();
      });

      colorBG.addEventListener('input', () => {
        settings.theme = 'custom';
        settings.backgroundColor = colorBG.value;
        themeSelect.value = 'custom';
        drawPaper();
      });

      colorMinor.addEventListener('input', () => {
        settings.theme = 'custom';
        settings.minorColor = colorMinor.value;
        themeSelect.value = 'custom';
        drawPaper();
      });

      colorMajor.addEventListener('input', () => {
        settings.theme = 'custom';
        settings.majorColor = colorMajor.value;
        themeSelect.value = 'custom';
        drawPaper();
      });

      opacitySlider.addEventListener('input', () => {
        settings.gridOpacity = parseInt(opacitySlider.value) / 100;
        document.getElementById('opacity-val-txt').textContent = `${opacitySlider.value}%`;
        drawPaper();
      });

      thicknessSlider.addEventListener('input', () => {
        settings.gridThickness = parseInt(thicknessSlider.value) / 100;
        document.getElementById('thickness-val-txt').textContent = `${settings.gridThickness.toFixed(2)}mm`;
        drawPaper();
      });

      marginSelect.addEventListener('change', () => {
        settings.marginType = marginSelect.value;
        if (settings.marginType === 'custom') {
          customMarginsFields.classList.remove('hidden');
        } else {
          customMarginsFields.classList.add('hidden');
        }
        drawPaper();
      });

      [mTopInput, mBottomInput, mLeftInput, mRightInput].forEach(inp => {
        inp.addEventListener('input', () => {
          settings.marginTop = parseFloat(mTopInput.value) || 0;
          settings.marginBottom = parseFloat(mBottomInput.value) || 0;
          settings.marginLeft = parseFloat(mLeftInput.value) || 0;
          settings.marginRight = parseFloat(mRightInput.value) || 0;
          drawPaper();
        });
      });

      checkPrintGuides.addEventListener('change', () => {
        settings.showPrintGuides = checkPrintGuides.checked;
        drawPaper();
      });

      checkCropMarks.addEventListener('change', () => {
        settings.showCropMarks = checkCropMarks.checked;
        drawPaper();
      });

      brushColorInput.addEventListener('input', () => {
        settings.drawColor = brushColorInput.value;
      });

      brushSlider.addEventListener('input', () => {
        settings.drawSize = parseInt(brushSlider.value) / 10;
        document.getElementById('brush-size-val').textContent = `${settings.drawSize.toFixed(1)}mm`;
      });

      document.querySelectorAll('.draw-tool-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          settings.activeTool = btn.getAttribute('data-tool');
          syncSidebarUi();
        });
      });

      btnUndo.addEventListener('click', undo);
      btnRedo.addEventListener('click', redo);
      
      btnClear.addEventListener('click', () => {
        if (confirm('Clear all drawings and annotations?')) {
          saveHistory();
          shapes = [];
          shapesRedoStack = [];
          drawPaper();
          updateUndoRedoButtons();
        }
      });

      window.addEventListener('keydown', (e) => {
        if (document.activeElement?.tagName === 'INPUT') return;
        if (e.ctrlKey && e.key.toLowerCase() === 'z') {
          e.preventDefault();
          undo();
        }
        if (e.ctrlKey && e.key.toLowerCase() === 'y') {
          e.preventDefault();
          redo();
        }
      });

      drawingCanvas.addEventListener('mousedown', (e) => {
        if (e.button === 1 || settings.activeTool === 'move') {
          isInteracting = true;
          lastX = e.clientX;
          lastY = e.clientY;
          drawingCanvas.style.cursor = 'grabbing';
          return;
        }
        if (e.button !== 0) return;

        isInteracting = true;
        const pt = screenToPaper(e.clientX, e.clientY);
        
        if (settings.activeTool === 'text') {
          textPopupPosition = { x: e.clientX, y: e.clientY };
          showTextPopup(pt);
        } else {
          saveHistory();
          currentStrokePoints = [pt];
          if (settings.activeTool === 'pencil' || settings.activeTool === 'pen' || settings.activeTool === 'eraser') {
            currentStrokePoints.push(pt);
          }
          drawOverlayShapes();
        }
      });

      drawingCanvas.addEventListener('mousemove', (e) => {
        if (!isInteracting) return;
        
        if (drawingCanvas.style.cursor === 'grabbing') {
          const dx = e.clientX - lastX;
          const dy = e.clientY - lastY;
          viewportState.panX += dx;
          viewportState.panY += dy;
          lastX = e.clientX;
          lastY = e.clientY;
          applyViewportTransform();
          return;
        }

        const pt = screenToPaper(e.clientX, e.clientY);
        if (settings.activeTool === 'pencil' || settings.activeTool === 'pen' || settings.activeTool === 'eraser') {
          currentStrokePoints.push(pt);
        } else if (['line', 'arrow', 'rect', 'circle'].includes(settings.activeTool)) {
          currentStrokePoints[1] = pt;
        }
        drawOverlayShapes();
      });

      window.addEventListener('mouseup', () => {
        if (!isInteracting) return;
        isInteracting = false;
        drawingCanvas.style.cursor = '';

        if (currentStrokePoints.length > 0) {
          shapes.push({
            type: settings.activeTool,
            points: [...currentStrokePoints],
            color: settings.drawColor,
            width: settings.drawSize
          });
          currentStrokePoints = [];
          drawOverlayShapes();
          updateUndoRedoButtons();
        }
      });

      drawingCanvas.addEventListener('touchstart', (e) => {
        if (e.touches.length === 1) {
          const touch = e.touches[0];
          if (settings.activeTool === 'move') {
            isInteracting = true;
            lastX = touch.clientX;
            lastY = touch.clientY;
            return;
          }
          isInteracting = true;
          const pt = screenToPaper(touch.clientX, touch.clientY);
          if (settings.activeTool === 'text') {
            textPopupPosition = { x: touch.clientX, y: touch.clientY };
            showTextPopup(pt);
          } else {
            saveHistory();
            currentStrokePoints = [pt];
            if (settings.activeTool === 'pencil' || settings.activeTool === 'pen' || settings.activeTool === 'eraser') {
              currentStrokePoints.push(pt);
            }
            drawOverlayShapes();
          }
          e.preventDefault();
        } else if (e.touches.length === 2) {
          isInteracting = true;
          touchCanceled = true;
          lastMouseX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
          lastMouseY = (e.touches[0].clientY + e.touches[1].clientY) / 2;
          lastTouchDist = Math.hypot(
            e.touches[0].clientX - e.touches[1].clientX,
            e.touches[0].clientY - e.touches[1].clientY
          );
          e.preventDefault();
        }
      }, { passive: false });

      drawingCanvas.addEventListener('touchmove', (e) => {
        if (!isInteracting) return;
        if (e.touches.length === 1) {
          const touch = e.touches[0];
          if (settings.activeTool === 'move') {
            const dx = touch.clientX - lastX;
            const dy = touch.clientY - lastY;
            viewportState.panX += dx;
            viewportState.panY += dy;
            lastX = touch.clientX;
            lastY = touch.clientY;
            applyViewportTransform();
            return;
          }
          const pt = screenToPaper(touch.clientX, touch.clientY);
          if (settings.activeTool === 'pencil' || settings.activeTool === 'pen' || settings.activeTool === 'eraser') {
            currentStrokePoints.push(pt);
          } else if (['line', 'arrow', 'rect', 'circle'].includes(settings.activeTool)) {
            currentStrokePoints[1] = pt;
          }
          drawOverlayShapes();
          e.preventDefault();
        } else if (e.touches.length === 2) {
          const midX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
          const midY = (e.touches[0].clientY + e.touches[1].clientY) / 2;
          const dist = Math.hypot(
            e.touches[0].clientX - e.touches[1].clientX,
            e.touches[0].clientY - e.touches[1].clientY
          );

          viewportState.panX += midX - lastMouseX;
          viewportState.panY += midY - lastMouseY;

          if (lastTouchDist > 0 && dist > 0) {
            const ratio = dist / lastTouchDist;
            viewportState.zoom = Math.max(0.2, Math.min(3.0, viewportState.zoom * ratio));
          }

          lastMouseX = midX;
          lastMouseY = midY;
          lastTouchDist = dist;
          applyViewportTransform();
          e.preventDefault();
        }
      }, { passive: false });

      drawingCanvas.addEventListener('touchend', () => {
        if (!isInteracting) return;
        isInteracting = false;
        if (currentStrokePoints.length > 0) {
          shapes.push({
            type: settings.activeTool,
            points: [...currentStrokePoints],
            color: settings.drawColor,
            width: settings.drawSize
          });
          currentStrokePoints = [];
          drawOverlayShapes();
          updateUndoRedoButtons();
        }
      });

      drawingCanvas.addEventListener('wheel', (e) => {
        e.preventDefault();
        const zoomFactor = e.deltaY < 0 ? 1.1 : 0.9;
        viewportState.zoom = Math.max(0.2, Math.min(3.0, viewportState.zoom * zoomFactor));
        applyViewportTransform();
      }, { passive: false });

      btnPrint.addEventListener('click', () => {
        preparePrintVector();
        window.print();
      });

      btnPNG.addEventListener('click', exportPNG);
      btnSVG.addEventListener('click', exportSVG);
      btnPDFRaster.addEventListener('click', exportPDFRaster);
      btnPDFVector.addEventListener('click', exportPDFVector);
      
      btnCopyURL.addEventListener('click', () => {
        const shareUrl = getShareableUrl();
        navigator.clipboard.writeText(shareUrl).then(() => {
          alert('Configuration link copied to clipboard!');
        }).catch(err => {
          alert('Could not copy link: ' + err);
        });
      });

      // Toolbar orientation toggler
      let toolbarOrient = localStorage.getItem('gmo-toolbar-orient') || 'vertical';

      function applyToolbarOrient() {
        if (!toolbar) return;
        if (toolbarOrient === 'vertical') {
          toolbar.classList.remove('top-4', 'left-1/2', '-translate-x-1/2', 'flex-row', 'flex-wrap');
          toolbar.classList.add('left-4', 'top-1/2', '-translate-y-1/2', 'flex-col');
        } else {
          toolbar.classList.remove('left-4', 'top-1/2', '-translate-y-1/2', 'flex-col');
          toolbar.classList.add('top-4', 'left-1/2', '-translate-x-1/2', 'flex-row', 'flex-wrap');
        }
      }

      applyToolbarOrient();

      toggleToolbarBtn?.addEventListener('click', () => {
        toolbarOrient = toolbarOrient === 'horizontal' ? 'vertical' : 'horizontal';
        localStorage.setItem('gmo-toolbar-orient', toolbarOrient);
        applyToolbarOrient();
      });

      // Browser native printing hook
      window.addEventListener('beforeprint', () => {
        preparePrintVector();
      });

      // Expand / Collapse sidebar sections
      document.querySelectorAll('.section-toggle').forEach(toggle => {
        toggle.addEventListener('click', () => {
          const content = toggle.nextElementSibling;
          const chevron = toggle.querySelector('.chevron-icon');
          if (content.classList.contains('hidden')) {
            content.classList.remove('hidden');
            chevron.classList.remove('-rotate-90');
          } else {
            content.classList.add('hidden');
            chevron.classList.add('-rotate-90');
          }
        });
      });

      // Preset selector dropdown listener
      const presetSelect = document.getElementById('premade-preset');
      presetSelect?.addEventListener('change', () => {
        const val = presetSelect.value;
        if (!val) return;
        
        saveHistory();
        
        if (val === 'default_green') {
          settings.gridType = 'green';
          settings.paperSize = 'A4';
          settings.orientation = 'portrait';
          settings.gridSpacing = 5.0;
          settings.majorInterval = 5;
          settings.theme = 'green';
        } else if (val === 'blueprint_draft') {
          settings.gridType = 'green';
          settings.paperSize = 'tabloid';
          settings.orientation = 'landscape';
          settings.gridSpacing = 5.0;
          settings.majorInterval = 5;
          settings.theme = 'blueprint';
        } else if (val === 'bujo_dot') {
          settings.gridType = 'dot';
          settings.paperSize = 'A5';
          settings.orientation = 'portrait';
          settings.gridSpacing = 5.0;
          settings.majorInterval = 0;
          settings.theme = 'classic';
        } else if (val === 'cartesian_xy') {
          settings.gridType = 'cartesian';
          settings.paperSize = 'letter';
          settings.orientation = 'portrait';
          settings.gridSpacing = 5.0;
          settings.majorInterval = 5;
          settings.theme = 'classic';
        } else if (val === '3d_isometric') {
          settings.gridType = 'isometric';
          settings.paperSize = 'A4';
          settings.orientation = 'landscape';
          settings.gridSpacing = 10.0;
          settings.majorInterval = 0;
          settings.theme = 'lightgray';
        } else if (val === 'polar_chart') {
          settings.gridType = 'polar';
          settings.paperSize = 'A4';
          settings.orientation = 'portrait';
          settings.gridSpacing = 5.0;
          settings.majorInterval = 0;
          settings.theme = 'blueprint';
        } else if (val === 'loglog_freq') {
          settings.gridType = 'loglog';
          settings.paperSize = 'A4';
          settings.orientation = 'landscape';
          settings.gridSpacing = 5.0;
          settings.majorInterval = 5;
          settings.theme = 'classic';
        }
        
        applyThemeColors();
        syncSidebarUi();
        updatePaperSize();
        drawPaper();
      });

      // Reset Settings button listener
      const btnResetSettings = document.getElementById('reset-settings-btn');
      btnResetSettings?.addEventListener('click', () => {
        if (confirm('Reset all grid parameters and themes to defaults? (Your drawings will not be cleared)')) {
          settings = {
            gridType: 'green',
            paperSize: 'A4',
            customWidth: 210,
            customHeight: 297,
            orientation: 'portrait',
            spacingUnit: 'mm',
            gridSpacing: 5.0,
            majorInterval: 5,
            theme: 'green',
            backgroundColor: '#fafdfa',
            minorColor: '#c2ebd0',
            majorColor: '#4fa368',
            gridOpacity: 0.85,
            gridThickness: 0.35,
            marginType: 'auto',
            marginTop: 10,
            marginBottom: 10,
            marginLeft: 10,
            marginRight: 10,
            showPrintGuides: true,
            showCropMarks: false,
            activeTool: 'move',
            drawColor: '#000000',
            drawSize: 1.0
          };
          window.location.hash = '';
          if (presetSelect) presetSelect.value = '';
          applyThemeColors();
          syncSidebarUi();
          updatePaperSize();
          drawPaper();
        }
      });

      const sidebarToggleBtn = document.getElementById('mobile-sidebar-toggle-btn');
      const closeSidebarBtn = document.getElementById('close-sidebar-btn');
      const sidebarPanel = document.getElementById('config-panel');
      
      sidebarToggleBtn?.addEventListener('click', () => {
        sidebarPanel.classList.remove('-translate-x-full');
        sidebarPanel.classList.add('translate-x-0', 'fixed', 'inset-y-0', 'left-0', 'w-80', 'z-40');
        sidebarBackdrop.classList.remove('hidden');
      });

      const closeSidebar = () => {
        sidebarPanel.classList.add('-translate-x-full');
        sidebarPanel.classList.remove('translate-x-0', 'fixed', 'inset-y-0', 'left-0', 'w-80', 'z-40');
        sidebarBackdrop.classList.add('hidden');
      };

      closeSidebarBtn?.addEventListener('click', closeSidebar);
      sidebarBackdrop.addEventListener('click', closeSidebar);
    }

    function updateSpacing() {
      const unit = unitSelect.value;
      const spacingPreset = spacingSelect.value;

      let spacingVal = 5.0;
      if (spacingPreset === 'custom') {
        customSpacingContainer.classList.remove('hidden');
        spacingVal = parseFloat(customSpacingInput.value) || 5.0;
      } else {
        customSpacingContainer.classList.add('hidden');
        spacingVal = parseFloat(spacingPreset);
      }

      if (unit === 'cm') {
        settings.gridSpacing = spacingVal * 10;
      } else if (unit === 'in') {
        settings.gridSpacing = spacingVal * 25.4;
      } else {
        settings.gridSpacing = spacingVal;
      }

      drawPaper();
    }

    let historyStack = [];
    function saveHistory() {
      const data = JSON.stringify(shapes);
      if (historyStack.length > 30) historyStack.shift();
      historyStack.push(data);
      shapesRedoStack = [];
    }

    function undo() {
      if (historyStack.length === 0) return;
      shapesRedoStack.push(JSON.stringify(shapes));
      const prev = JSON.parse(historyStack.pop());
      shapes = prev;
      drawPaper();
      updateUndoRedoButtons();
    }

    function redo() {
      if (shapesRedoStack.length === 0) return;
      historyStack.push(JSON.stringify(shapes));
      const next = JSON.parse(shapesRedoStack.pop());
      shapes = next;
      drawPaper();
      updateUndoRedoButtons();
    }

    function updateUndoRedoButtons() {
      btnUndo.disabled = historyStack.length === 0;
      btnRedo.disabled = shapesRedoStack.length === 0;
    }

    let activeTextPoint = null;
    function showTextPopup(pt) {
      activeTextPoint = pt;
      textInput.value = '';
      
      textPopup.style.left = `${textPopupPosition.x}px`;
      textPopup.style.top = `${textPopupPosition.y}px`;
      textPopup.classList.remove('hidden');
      textInput.focus();
    }

    textCancel.addEventListener('click', () => {
      textPopup.classList.add('hidden');
      activeTextPoint = null;
    });

    textOK.addEventListener('click', submitText);
    textInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') submitText();
    });

    function submitText() {
      const text = textInput.value.trim();
      if (text && activeTextPoint) {
        saveHistory();
        shapes.push({
          type: 'text',
          points: [activeTextPoint],
          color: settings.drawColor,
          width: settings.drawSize,
          text
        });
        drawOverlayShapes();
        updateUndoRedoButtons();
      }
      textPopup.classList.add('hidden');
      activeTextPoint = null;
    }

    function preparePrintVector() {
      let W = paperCanvas.width / pixelsPerMm;
      let H = paperCanvas.height / pixelsPerMm;

      let mL = settings.marginType === 'auto' ? 10 : settings.marginLeft;
      let mR = settings.marginType === 'auto' ? 10 : settings.marginRight;
      let mT = settings.marginType === 'auto' ? 10 : settings.marginTop;
      let mB = settings.marginType === 'auto' ? 10 : settings.marginBottom;

      const svgStr = generateSVGString(W, H, mL, mR, mT, mB, settings, shapes);
      printVectorContainer.innerHTML = svgStr;
    }

    function exportPNG() {
      const tempCanvas = document.createElement('canvas');
      const tempCtx = tempCanvas.getContext('2d');
      
      const wMm = paperCanvas.width / pixelsPerMm;
      const hMm = paperCanvas.height / pixelsPerMm;
      const dpiScale = 300 / 25.4;

      tempCanvas.width = Math.round(wMm * dpiScale);
      tempCanvas.height = Math.round(hMm * dpiScale);
      tempCtx.scale(dpiScale, dpiScale);

      tempCtx.fillStyle = settings.backgroundColor;
      tempCtx.fillRect(0, 0, wMm, hMm);

      let mL = settings.marginType === 'auto' ? 10 : settings.marginLeft;
      let mR = settings.marginType === 'auto' ? 10 : settings.marginRight;
      let mT = settings.marginType === 'auto' ? 10 : settings.marginTop;
      let mB = settings.marginType === 'auto' ? 10 : settings.marginBottom;
      const left = mL;
      const right = wMm - mR;
      const top = mT;
      const bottom = hMm - mB;

      tempCtx.save();
      tempCtx.beginPath();
      tempCtx.rect(left, top, right - left, bottom - top);
      tempCtx.clip();

      const spacing = settings.gridSpacing;
      const major = settings.majorInterval;

      tempCtx.globalAlpha = settings.gridOpacity;
      tempCtx.lineCap = 'round';
      tempCtx.lineJoin = 'round';

      if (settings.gridType === 'square' || settings.gridType === 'green' || settings.gridType === 'cartesian') {
        let col = 0;
        for (let x = left; x <= right + 0.01; x += spacing) {
          const isMajor = major > 0 && col % major === 0;
          tempCtx.strokeStyle = isMajor ? settings.majorColor : settings.minorColor;
          tempCtx.lineWidth = isMajor ? settings.gridThickness : settings.gridThickness / 2;
          tempCtx.beginPath(); tempCtx.moveTo(x, top); tempCtx.lineTo(x, bottom); tempCtx.stroke();
          col++;
        }
        let row = 0;
        for (let y = top; y <= bottom + 0.01; y += spacing) {
          const isMajor = major > 0 && row % major === 0;
          tempCtx.strokeStyle = isMajor ? settings.majorColor : settings.minorColor;
          tempCtx.lineWidth = isMajor ? settings.gridThickness : settings.gridThickness / 2;
          tempCtx.beginPath(); tempCtx.moveTo(left, y); tempCtx.lineTo(right, y); tempCtx.stroke();
          row++;
        }
        if (settings.gridType === 'cartesian') {
          const cx = left + (right - left) / 2;
          const cy = top + (bottom - top) / 2;
          tempCtx.strokeStyle = settings.majorColor;
          tempCtx.lineWidth = settings.gridThickness * 1.5;
          tempCtx.beginPath(); tempCtx.moveTo(left, cy); tempCtx.lineTo(right, cy); tempCtx.stroke();
          tempCtx.beginPath(); tempCtx.moveTo(cx, top); tempCtx.lineTo(cx, bottom); tempCtx.stroke();

          tempCtx.fillStyle = settings.majorColor;
          tempCtx.font = '2.5px sans-serif';
          tempCtx.textAlign = 'center';
          let labelIndex = 0;
          for (let x = cx + spacing; x <= right; x += spacing) {
            labelIndex++;
            if (labelIndex % 2 === 0) tempCtx.fillText(labelIndex.toString(), x, cy + 3.5);
          }
          labelIndex = 0;
          for (let x = cx - spacing; x >= left; x -= spacing) {
            labelIndex++;
            if (labelIndex % 2 === 0) tempCtx.fillText(`-${labelIndex}`, x, cy + 3.5);
          }
          tempCtx.textAlign = 'right';
          labelIndex = 0;
          for (let y = cy - spacing; y >= top; y -= spacing) {
            labelIndex++;
            if (labelIndex % 2 === 0) tempCtx.fillText(labelIndex.toString(), cx - 1.5, y + 0.8);
          }
          labelIndex = 0;
          for (let y = cy + spacing; y <= bottom; y += spacing) {
            labelIndex++;
            if (labelIndex % 2 === 0) tempCtx.fillText(`-${labelIndex}`, cx - 1.5, y + 0.8);
          }
        }
      } else if (settings.gridType === 'dot') {
        tempCtx.fillStyle = settings.minorColor;
        for (let x = left; x <= right + 0.01; x += spacing) {
          for (let y = top; y <= bottom + 0.01; y += spacing) {
            tempCtx.beginPath(); tempCtx.arc(x, y, settings.gridThickness / 2, 0, 2 * Math.PI); tempCtx.fill();
          }
        }
      } else if (settings.gridType === 'isometric') {
        tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
        for (let x = left; x <= right + 0.01; x += spacing) {
          tempCtx.beginPath(); tempCtx.moveTo(x, top); tempCtx.lineTo(x, bottom); tempCtx.stroke();
        }
        const stepC = spacing * Math.sqrt(3);
        const minC = top - 0.57735 * right;
        const maxC = bottom - 0.57735 * left;
        for (let c = minC; c <= maxC; c += stepC) {
          tempCtx.beginPath(); tempCtx.moveTo(left, 0.57735 * left + c); tempCtx.lineTo(right, 0.57735 * right + c); tempCtx.stroke();
        }
        const minC2 = top + 0.57735 * left;
        const maxC2 = bottom + 0.57735 * right;
        for (let c = minC2; c <= maxC2; c += stepC) {
          tempCtx.beginPath(); tempCtx.moveTo(left, -0.57735 * left + c); tempCtx.lineTo(right, -0.57735 * right + c); tempCtx.stroke();
        }
      } else if (settings.gridType === 'polar') {
        const cx = left + (right - left) / 2;
        const cy = top + (bottom - top) / 2;
        const maxRadius = Math.sqrt((right - left) ** 2 + (bottom - top) ** 2) / 2;
        tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
        for (let r = spacing; r <= maxRadius; r += spacing) {
          tempCtx.beginPath(); tempCtx.arc(cx, cy, r, 0, 2 * Math.PI); tempCtx.stroke();
        }
        for (let angle = 0; angle < 360; angle += 15) {
          const rad = (angle * Math.PI) / 180;
          tempCtx.beginPath(); tempCtx.moveTo(cx, cy); tempCtx.lineTo(cx + maxRadius * Math.cos(rad), cy + maxRadius * Math.sin(rad)); tempCtx.stroke();
        }
      } else if (settings.gridType === 'loglog' || settings.gridType === 'semilog') {
        const numDecadesX = settings.gridType === 'loglog' ? 3 : 5;
        const numDecadesY = 4;
        const decWidth = (right - left) / numDecadesX;
        const decHeight = (bottom - top) / numDecadesY;
        if (settings.gridType === 'loglog') {
          for (let d = 0; d < numDecadesX; d++) {
            const dStart = left + d * decWidth;
            tempCtx.strokeStyle = settings.majorColor; tempCtx.lineWidth = settings.gridThickness;
            tempCtx.beginPath(); tempCtx.moveTo(dStart, top); tempCtx.lineTo(dStart, bottom); tempCtx.stroke();
            tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
            for (let k = 2; k <= 9; k++) {
              const x = dStart + Math.log10(k) * decWidth;
              tempCtx.beginPath(); tempCtx.moveTo(x, top); tempCtx.lineTo(x, bottom); tempCtx.stroke();
            }
          }
          tempCtx.strokeStyle = settings.majorColor; tempCtx.lineWidth = settings.gridThickness;
          tempCtx.beginPath(); tempCtx.moveTo(right, top); tempCtx.lineTo(right, bottom); tempCtx.stroke();
        } else {
          for (let x = left; x <= right + 0.01; x += spacing) {
            tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
            tempCtx.beginPath(); tempCtx.moveTo(x, top); tempCtx.lineTo(x, bottom); tempCtx.stroke();
          }
        }
        for (let d = 0; d < numDecadesY; d++) {
          const dStart = bottom - d * decHeight;
          tempCtx.strokeStyle = settings.majorColor; tempCtx.lineWidth = settings.gridThickness;
          tempCtx.beginPath(); tempCtx.moveTo(left, dStart); tempCtx.lineTo(right, dStart); tempCtx.stroke();
          tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
          for (let k = 2; k <= 9; k++) {
            const y = dStart - Math.log10(k) * decHeight;
            tempCtx.beginPath(); tempCtx.moveTo(left, y); tempCtx.lineTo(right, y); tempCtx.stroke();
          }
        }
        tempCtx.strokeStyle = settings.majorColor; tempCtx.lineWidth = settings.gridThickness;
        tempCtx.beginPath(); tempCtx.moveTo(left, top); tempCtx.lineTo(right, top); tempCtx.stroke();
      } else if (settings.gridType === 'hexagonal') {
        const r = spacing; const h = r * Math.sqrt(3);
        tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
        const cols = Math.ceil((right - left) / (r * 1.5)) + 1;
        const rows = Math.ceil((bottom - top) / h) + 1;
        for (let col = -1; col < cols; col++) {
          for (let row = -1; row < rows; row++) {
            const cx = left + col * r * 1.5;
            const cy = top + row * h + (col % 2 === 0 ? 0 : h / 2);
            tempCtx.beginPath();
            for (let i = 0; i < 6; i++) {
              const angle = (i * Math.PI) / 3;
              tempCtx.lineTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle));
            }
            tempCtx.closePath(); tempCtx.stroke();
          }
        }
      } else if (settings.gridType === 'triangular') {
        const dy = spacing * Math.sqrt(3) / 2;
        tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
        for (let y = top; y <= bottom + 0.01; y += dy) {
          tempCtx.beginPath(); tempCtx.moveTo(left, y); tempCtx.lineTo(right, y); tempCtx.stroke();
        }
        const stepC = spacing;
        const minC = top - 1.73205 * right;
        const maxC = bottom - 1.73205 * left;
        for (let c = minC; c <= maxC; c += stepC) {
          tempCtx.beginPath(); tempCtx.moveTo(left, 1.73205 * left + c); tempCtx.lineTo(right, 1.73205 * right + c); tempCtx.stroke();
        }
        const minC2 = top + 1.73205 * left;
        const maxC2 = bottom + 1.73205 * right;
        for (let c = minC2; c <= maxC2; c += stepC) {
          tempCtx.beginPath(); tempCtx.moveTo(left, -1.73205 * left + c); tempCtx.lineTo(right, -1.73205 * right + c); tempCtx.stroke();
        }
      }

      tempCtx.restore();

      if (settings.showPrintGuides) {
        tempCtx.strokeStyle = settings.majorColor; tempCtx.lineWidth = 0.25; tempCtx.setLineDash([2, 2]);
        tempCtx.beginPath(); tempCtx.rect(left, top, right - left, bottom - top); tempCtx.stroke();
        tempCtx.setLineDash([]);
      }

      if (settings.showCropMarks) {
        tempCtx.strokeStyle = '#000000'; tempCtx.lineWidth = 0.25;
        const size = 5;
        tempCtx.beginPath();
        tempCtx.moveTo(0, top); tempCtx.lineTo(size, top); tempCtx.moveTo(left, 0); tempCtx.lineTo(left, size);
        tempCtx.moveTo(wMm, top); tempCtx.lineTo(wMm - size, top); tempCtx.moveTo(right, 0); tempCtx.lineTo(right, size);
        tempCtx.moveTo(0, bottom); tempCtx.lineTo(size, bottom); tempCtx.moveTo(left, hMm); tempCtx.lineTo(left, hMm - size);
        tempCtx.moveTo(wMm, bottom); tempCtx.lineTo(wMm - size, bottom); tempCtx.moveTo(right, hMm); tempCtx.lineTo(right, hMm - size);
        tempCtx.stroke();
      }

      shapes.forEach(shape => {
        drawSingleShape(tempCtx, shape);
      });

      const url = tempCanvas.toDataURL('image/png');
      const a = document.createElement('a');
      a.download = `graph-paper-${settings.gridType}-${settings.paperSize.toLowerCase()}.png`;
      a.href = url;
      a.click();
    }

