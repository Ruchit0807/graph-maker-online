---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Print Graph Paper Online – Free Printable Graph Paper Generator"
  description="Create and print customizable graph paper online. Generate A4, Letter, Engineering, Polar, Isometric, Log, Dot Grid and more. Export PDF, SVG and PNG for free."
>
  <div class="flex flex-col h-screen w-screen overflow-hidden bg-canvas text-ink transition-colors duration-150 print:h-auto print:overflow-visible print:bg-white" id="app-wrapper">
    
    <!-- Premium Header -->
    <Header activeTab="generator" />

    <!-- Split Screen Dashboard Workspace -->
    <main class="flex-1 flex flex-col lg:flex-row overflow-hidden relative print:block print:h-auto print:overflow-visible">
      
      <!-- Central Viewport & Paper Preview -->
      <div class="flex-1 bg-[#121212] dark:bg-[#000000] relative flex items-center justify-center p-4 sm:p-8 overflow-hidden select-none print:bg-white print:p-0 print:block">
        
        <!-- Hover Zoom & Pan Navigation HUD Controls (Floating Bottom-Left) -->
        <div class="absolute bottom-4 left-4 z-10 flex items-center gap-1 bg-canvas/90 border border-hairline p-1 rounded-md shadow-md backdrop-blur-xs pointer-events-auto no-print">
          <button id="view-zoom-in" class="h-7 w-7 flex items-center justify-center rounded-xs text-ink hover:bg-canvas-soft-2 transition-colors" title="Zoom In">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
          </button>
          <button id="view-zoom-out" class="h-7 w-7 flex items-center justify-center rounded-xs text-ink hover:bg-canvas-soft-2 transition-colors" title="Zoom Out">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" />
            </svg>
          </button>
          <button id="view-reset" class="h-7 px-2 flex items-center justify-center rounded-xs text-ink hover:bg-canvas-soft-2 text-[10px] font-mono transition-colors" title="Reset Viewport">
            Reset
          </button>
          <div class="h-4 w-px bg-hairline mx-0.5"></div>
          <span id="zoom-hud-txt" class="text-[10px] font-mono font-medium text-mute px-1.5">100%</span>
        </div>
        <!-- Drawing Instruments Floating Hub (Floating Left-Center) -->
        <div id="drawing-toolbar" class="absolute left-4 top-1/2 -translate-y-1/2 z-10 flex flex-col items-center gap-1 bg-canvas/95 border border-hairline p-1.5 rounded-md shadow-md backdrop-blur-xs pointer-events-auto no-print">
          <button data-tool="move" class="draw-tool-btn active h-7 px-2.5 flex items-center gap-1.5 rounded-xs text-ink hover:bg-canvas-soft-2 text-[10px] font-semibold transition-colors" title="Pan and Move Paper">
            <svg class="h-3.5 w-3.5 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
            </svg>
            <span class="hidden sm:inline">Move</span>
          </button>
          <div class="h-4 w-px bg-hairline mx-0.5"></div>
          
          <button data-tool="pen" class="draw-tool-btn h-7 w-7 sm:w-auto sm:px-2 flex items-center justify-center rounded-xs text-ink hover:bg-canvas-soft-2 text-[10px] font-semibold transition-colors gap-1.5" title="Smooth Pen Brush">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
            </svg>
            <span class="hidden sm:inline">Pen</span>
          </button>
          <button data-tool="pencil" class="draw-tool-btn h-7 w-7 sm:w-auto sm:px-2 flex items-center justify-center rounded-xs text-ink hover:bg-canvas-soft-2 text-[10px] font-semibold transition-colors gap-1.5" title="Fine Pencil Line">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-2-9-7-2-2 7-7 2 9-2zm0 0L9 9" />
            </svg>
            <span class="hidden sm:inline">Pencil</span>
          </button>
          <button data-tool="line" class="draw-tool-btn h-7 w-7 sm:w-auto sm:px-2 flex items-center justify-center rounded-xs text-ink hover:bg-canvas-soft-2 text-[10px] font-semibold transition-colors gap-1.5" title="Straight Line">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 20L20 4" />
            </svg>
            <span class="hidden sm:inline">Line</span>
          </button>
          <button data-tool="arrow" class="draw-tool-btn h-7 w-7 sm:w-auto sm:px-2 flex items-center justify-center rounded-xs text-ink hover:bg-canvas-soft-2 text-[10px] font-semibold transition-colors gap-1.5" title="Directional Arrow">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
            <span class="hidden sm:inline">Arrow</span>
          </button>
          <button data-tool="rect" class="draw-tool-btn h-7 w-7 sm:w-auto sm:px-2 flex items-center justify-center rounded-xs text-ink hover:bg-canvas-soft-2 text-[10px] font-semibold transition-colors gap-1.5" title="Rectangle Shape">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v14a1 1 0 01-1 1H5a1 1 0 01-1-1V5z" />
            </svg>
            <span class="hidden sm:inline">Rect</span>
          </button>
          <button data-tool="circle" class="draw-tool-btn h-7 w-7 sm:w-auto sm:px-2 flex items-center justify-center rounded-xs text-ink hover:bg-canvas-soft-2 text-[10px] font-semibold transition-colors gap-1.5" title="Circle Shape">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="9" />
            </svg>
            <span class="hidden sm:inline">Circle</span>
          </button>
          <button data-tool="text" class="draw-tool-btn h-7 w-7 sm:w-auto sm:px-2 flex items-center justify-center rounded-xs text-ink hover:bg-canvas-soft-2 text-[10px] font-semibold transition-colors gap-1.5" title="Insert Text Labels">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M12 6v14m-3 0h6" />
            </svg>
            <span class="hidden sm:inline">Text</span>
          </button>
          <button data-tool="eraser" class="draw-tool-btn h-7 w-7 sm:w-auto sm:px-2 flex items-center justify-center rounded-xs text-error hover:bg-error-soft text-[10px] font-semibold transition-colors gap-1.5" title="Erase Drawn Items">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-4v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
            <span class="hidden sm:inline">Eraser</span>
          </button>

          <div class="h-4 w-px bg-hairline mx-0.5"></div>

          <!-- Undo/Redo/Clear -->
          <button id="draw-undo" class="h-7 w-7 flex items-center justify-center rounded-xs text-ink hover:bg-canvas-soft-2 disabled:opacity-30 disabled:hover:bg-transparent transition-colors" title="Undo (Ctrl+Z)" disabled>
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" />
            </svg>
          </button>
          <button id="draw-redo" class="h-7 w-7 flex items-center justify-center rounded-xs text-ink hover:bg-canvas-soft-2 disabled:opacity-30 disabled:hover:bg-transparent transition-colors" title="Redo (Ctrl+Y)" disabled>
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 10H11a8 8 0 00-8 8v2m18-8l-6 6m6-6l-6-6" />
            </svg>
          </button>
          <button id="draw-clear" class="h-7 px-2 flex items-center justify-center rounded-xs text-error hover:bg-error-soft text-[10px] font-semibold transition-colors" title="Clear Canvas Overlay">
            Clear
          </button>
          
          <div class="h-4 w-px bg-hairline mx-0.5"></div>

          <!-- Toolbar Orientation Switcher -->
          <button id="toggle-toolbar-orient" class="h-7 w-7 flex items-center justify-center rounded-xs text-ink hover:bg-canvas-soft-2 transition-colors" title="Toggle Toolbar Layout (Horizontal/Vertical)">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7" />
            </svg>
          </button>
        </div>

        <!-- Floating Text Editor Input overlay (renders dynamically during text creation) -->
        <div id="text-editor-popup" class="absolute hidden bg-canvas border border-hairline shadow-md p-2 rounded z-20 max-w-xs">
          <input type="text" id="text-editor-input" placeholder="Type text here..." class="h-8 w-full border border-hairline px-2 text-xs focus:outline-none focus:border-hairline-strong rounded-sm" />
          <div class="flex justify-end gap-1.5 mt-2">
            <button id="text-editor-cancel" class="text-[10px] text-mute hover:text-ink px-2 py-1 rounded">Cancel</button>
            <button id="text-editor-ok" class="text-[10px] font-semibold text-white bg-primary px-3 py-1 rounded">Place</button>
          </div>
        </div>

        <!-- Physical Grid Sheet Wrapper (CSS transformed zoom/pan container) -->
        <div id="paper-shadow-wrapper" class="shadow-2xl bg-white origin-center border border-hairline relative transition-all duration-75 print:shadow-none print:border-none print:m-0 print:p-0 print:transform-none!">
          <canvas id="paper-canvas" class="w-full h-full block bg-transparent print:w-full print:h-full"></canvas>
          
          <!-- Interactive Drawing Overlay Canvas (same size, overlays grid) -->
          <canvas id="drawing-canvas" class="absolute inset-0 w-full h-full block bg-transparent pointer-events-auto print:w-full print:h-full"></canvas>
        </div>

        <!-- Print-only Hidden Vector Graphic Wrapper moved below layout boundary -->

      </div>

      <!-- Settings Configurations Sidebar (Panel Right) -->
      <aside id="config-panel" class="w-full lg:w-[380px] h-[50vh] lg:h-full border-t lg:border-t-0 lg:border-l border-hairline bg-canvas-soft flex flex-col overflow-y-auto no-scrollbar shrink-0 select-none print:hidden z-10 shadow-2xl lg:shadow-none">
        
        <!-- Header status bar -->
        <div class="px-6 py-4 border-b border-hairline flex flex-col gap-2 bg-canvas/30">
          <div class="flex items-center justify-between">
            <span class="font-mono text-[10px] uppercase tracking-wider text-mute">Grid Configuration Panel</span>
            <button id="reset-settings-btn" class="px-2 py-0.5 text-[9px] font-mono text-mute hover:text-error border border-hairline hover:border-error-soft rounded-sm transition-colors bg-canvas focus:outline-none" title="Reset all grid parameters to defaults">
              Reset
            </button>
          </div>
          <p class="text-xs text-body">Customize paper geometry, templates, colors, and export.</p>
        </div>

        <!-- Scrollable settings fields container -->
        <div class="p-6 flex flex-col gap-6">

          <!-- Premade Presets Selector -->
          <div class="rounded-md border border-hairline bg-canvas p-4 shadow-sm">
            <h4 class="font-sans text-[11px] font-semibold uppercase tracking-wider text-mute">Premade Presets</h4>
            <div class="flex flex-col gap-1.5 mt-2">
              <label for="premade-preset" class="text-[10px] font-semibold text-body">Select Template</label>
              <select id="premade-preset" class="w-full h-8 rounded-sm border border-hairline bg-canvas text-xs px-2.5 text-ink focus:outline-none">
                <option value="" disabled selected>Select a ready-to-use template...</option>
                <option value="default_green">Default Green Engineering Sheet (A4)</option>
                <option value="blueprint_draft">Blueprint Engineering Draft (Tabloid Landscape)</option>
                <option value="bujo_dot">Bullet Journal Dot Grid (A5 Portrait)</option>
                <option value="cartesian_xy">Cartesian XY Math Plotter (Letter Portrait)</option>
                <option value="3d_isometric">3D Isometric Sketchpad (A4 Landscape)</option>
                <option value="polar_chart">Polar Radial Graph (A4 Portrait)</option>
                <option value="loglog_freq">Log-Log Analysis Sheet (A4 Landscape)</option>
              </select>
            </div>
          </div>

          <!-- 1. Graph Paper Type Select -->
          <div class="rounded-md border border-hairline bg-canvas shadow-sm overflow-hidden">
            <button class="section-toggle w-full px-4 py-3 flex items-center justify-between text-left focus:outline-none hover:bg-canvas-soft-2 transition-colors">
              <h4 class="font-sans text-[11px] font-semibold uppercase tracking-wider text-mute">1. Grid Paper Template</h4>
              <svg class="chevron-icon h-3 w-3 text-mute transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="section-content p-4 border-t border-hairline">
              <div class="grid grid-cols-2 gap-2">
                <button data-type="square" class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all hover:bg-canvas-soft-2 focus:outline-none">
                  <span class="text-xs font-medium text-ink">Square Grid</span>
                  <span class="text-[9px] text-mute font-mono">Standard math</span>
                </button>
                <button data-type="green" class="grid-selector flex flex-col items-center justify-center rounded-sm border border-primary bg-canvas p-2.5 text-center transition-all hover:bg-canvas-soft-2 focus:outline-none">
                  <span class="text-xs font-semibold text-ink">Univ Green</span>
                  <span class="text-[9px] text-mute font-mono">Engineering</span>
                </button>
                <button data-type="cartesian" class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all hover:bg-canvas-soft-2 focus:outline-none">
                  <span class="text-xs font-medium text-ink">Cartesian XY</span>
                  <span class="text-[9px] text-mute font-mono">Numbered Axes</span>
                </button>
                <button data-type="dot" class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all hover:bg-canvas-soft-2 focus:outline-none">
                  <span class="text-xs font-medium text-ink">Dot Grid</span>
                  <span class="text-[9px] text-mute font-mono">Bullet Journal</span>
                </button>
                <button data-type="isometric" class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all hover:bg-canvas-soft-2 focus:outline-none">
                  <span class="text-xs font-medium text-ink">Isometric Grid</span>
                  <span class="text-[9px] text-mute font-mono">3D Drafting</span>
                </button>
                <button data-type="polar" class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all hover:bg-canvas-soft-2 focus:outline-none">
                  <span class="text-xs font-medium text-ink">Polar Coordinates</span>
                  <span class="text-[9px] text-mute font-mono">Circular Bands</span>
                </button>
                <button data-type="loglog" class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all hover:bg-canvas-soft-2 focus:outline-none">
                  <span class="text-xs font-medium text-ink">Log-Log Grid</span>
                  <span class="text-[9px] text-mute font-mono">Log Decades</span>
                </button>
                <button data-type="semilog" class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all hover:bg-canvas-soft-2 focus:outline-none">
                  <span class="text-xs font-medium text-ink">Semi-Log Y</span>
                  <span class="text-[9px] text-mute font-mono">Linear X / Log Y</span>
                </button>
                <button data-type="hexagonal" class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all hover:bg-canvas-soft-2 focus:outline-none">
                  <span class="text-xs font-medium text-ink">Hexagonal</span>
                  <span class="text-[9px] text-mute font-mono">Hex Tiling</span>
                </button>
                <button data-type="triangular" class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all hover:bg-canvas-soft-2 focus:outline-none">
                  <span class="text-xs font-medium text-ink">Triangular Grid</span>
                  <span class="text-[9px] text-mute font-mono">3-Axis Triangles</span>
                </button>
                <button data-type="blank" class="grid-selector flex flex-col items-center justify-center rounded-sm border border-hairline bg-canvas p-2.5 text-center transition-all hover:bg-canvas-soft-2 focus:outline-none">
                  <span class="text-xs font-medium text-ink">Blank Paper</span>
                  <span class="text-[9px] text-mute font-mono">Margins only</span>
                </button>
              </div>
            </div>
          </div>

          <!-- 2. Paper Layout Settings -->
          <div class="rounded-md border border-hairline bg-canvas shadow-sm overflow-hidden">
            <button class="section-toggle w-full px-4 py-3 flex items-center justify-between text-left focus:outline-none hover:bg-canvas-soft-2 transition-colors">
              <h4 class="font-sans text-[11px] font-semibold uppercase tracking-wider text-mute">2. Paper Geometry</h4>
              <svg class="chevron-icon h-3 w-3 text-mute transition-transform duration-200 -rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="section-content p-4 border-t border-hairline hidden">
              <div class="flex flex-col gap-1.5">
                <label for="paper-size" class="text-[10px] font-semibold text-body">Paper Size Format</label>
                <select id="paper-size" class="w-full h-8 rounded-sm border border-hairline bg-canvas text-xs px-2.5 text-ink focus:outline-none">
                  <option value="A4">A4 (210 &times; 297 mm)</option>
                  <option value="A3">A3 (297 &times; 420 mm)</option>
                  <option value="A5">A5 (148 &times; 210 mm)</option>
                  <option value="A2">A2 (420 &times; 594 mm)</option>
                  <option value="letter">Letter (8.5 &times; 11 in)</option>
                  <option value="legal">Legal (8.5 &times; 14 in)</option>
                  <option value="tabloid">Tabloid (11 &times; 17 in)</option>
                  <option value="custom">Custom Dimensions...</option>
                </select>
              </div>

              <!-- Custom width and height fields -->
              <div id="custom-dims" class="hidden grid grid-cols-2 gap-2 mt-2">
                <div>
                  <label for="custom-w" class="text-[9px] font-mono text-mute block mb-0.5">Width</label>
                  <input type="number" id="custom-w" value="210" class="w-full h-8 rounded-sm border border-hairline bg-canvas text-xs px-2 text-ink focus:outline-none" />
                </div>
                <div>
                  <label for="custom-h" class="text-[9px] font-mono text-mute block mb-0.5">Height</label>
                  <input type="number" id="custom-h" value="297" class="w-full h-8 rounded-sm border border-hairline bg-canvas text-xs px-2 text-ink focus:outline-none" />
                </div>
              </div>

              <div class="flex flex-col gap-1.5 mt-3">
                <label class="text-[10px] font-semibold text-body">Orientation</label>
                <div class="flex gap-2">
                  <button id="orient-portrait" class="orient-btn flex-1 py-1.5 text-center text-xs font-semibold rounded-sm border border-primary bg-canvas text-ink focus:outline-none">Portrait</button>
                  <button id="orient-landscape" class="orient-btn flex-1 py-1.5 text-center text-xs font-medium rounded-sm border border-hairline bg-canvas text-ink focus:outline-none">Landscape</button>
                </div>
              </div>
            </div>
          </div>

          <!-- 3. Grid Details (Spacing) -->
          <div class="rounded-md border border-hairline bg-canvas shadow-sm overflow-hidden">
            <button class="section-toggle w-full px-4 py-3 flex items-center justify-between text-left focus:outline-none hover:bg-canvas-soft-2 transition-colors">
              <h4 class="font-sans text-[11px] font-semibold uppercase tracking-wider text-mute">3. Grid Spacing</h4>
              <svg class="chevron-icon h-3 w-3 text-mute transition-transform duration-200 -rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="section-content p-4 border-t border-hairline hidden">
              <div class="grid grid-cols-2 gap-2">
                <div>
                  <label for="spacing-unit" class="text-[10px] font-semibold text-body block mb-1">Unit</label>
                  <select id="spacing-unit" class="w-full h-8 rounded-sm border border-hairline bg-canvas text-xs px-2.5 text-ink focus:outline-none">
                    <option value="mm">mm</option>
                    <option value="cm">cm</option>
                    <option value="in">inch</option>
                  </select>
                </div>
                <div>
                  <label for="grid-spacing-preset" class="text-[10px] font-semibold text-body block mb-1">Grid Spacing</label>
                  <select id="grid-spacing-preset" class="w-full h-8 rounded-sm border border-hairline bg-canvas text-xs px-2.5 text-ink focus:outline-none">
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                    <option value="5" selected>5</option>
                    <option value="8">8</option>
                    <option value="10">10</option>
                    <option value="custom">Custom...</option>
                  </select>
                </div>
              </div>

              <!-- Custom Spacing Input -->
              <div id="custom-spacing-container" class="hidden flex-col gap-1 mt-2">
                <label for="custom-spacing-input" class="text-[9px] font-mono text-mute">Custom Spacing Value</label>
                <input type="number" id="custom-spacing-input" step="any" value="5.0" class="w-full h-8 rounded-sm border border-hairline bg-canvas text-xs px-2.5 text-ink focus:outline-none" />
              </div>

              <div class="flex flex-col gap-1.5 mt-3">
                <label for="major-interval" class="text-[10px] font-semibold text-body">Major Bold Line Interval</label>
                <select id="major-interval" class="w-full h-8 rounded-sm border border-hairline bg-canvas text-xs px-2.5 text-ink focus:outline-none">
