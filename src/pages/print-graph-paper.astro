    async function exportPDFRaster() {
      try {
        const jsPDFClass = await getJsPDF();
        
        const wMm = paperCanvas.width / pixelsPerMm;
        const hMm = paperCanvas.height / pixelsPerMm;

        const tempCanvas = document.createElement('canvas');
        const tempCtx = tempCanvas.getContext('2d');
        const dpiScale = 300 / 25.4;
        
        tempCanvas.width = Math.round(wMm * dpiScale);
        tempCanvas.height = Math.round(hMm * dpiScale);
        tempCtx.scale(dpiScale, dpiScale);

        tempCtx.fillStyle = settings.backgroundColor;
        tempCtx.fillRect(0, 0, wMm, hMm);
        
        let mL = settings.marginType === 'auto' ? 10 : settings.marginLeft;
        let mR = settings.marginType === 'auto' ? 10 : settings.marginRight;
        let mT = settings.marginType === 'auto' ? 10 : settings.marginTop;
        let mB = settings.marginType === 'auto' ? 10 : settings.marginBottom;
        const left = mL;
        const right = wMm - mR;
        const top = mT;
        const bottom = hMm - mB;

        tempCtx.save();
        tempCtx.beginPath();
        tempCtx.rect(left, top, right - left, bottom - top);
        tempCtx.clip();

        const spacing = settings.gridSpacing;
        const major = settings.majorInterval;

        tempCtx.globalAlpha = settings.gridOpacity;
        tempCtx.lineCap = 'round';
        tempCtx.lineJoin = 'round';

        if (settings.gridType === 'square' || settings.gridType === 'green' || settings.gridType === 'cartesian') {
          let col = 0;
          for (let x = left; x <= right + 0.01; x += spacing) {
            const isMajor = major > 0 && col % major === 0;
            tempCtx.strokeStyle = isMajor ? settings.majorColor : settings.minorColor;
            tempCtx.lineWidth = isMajor ? settings.gridThickness : settings.gridThickness / 2;
            tempCtx.beginPath(); tempCtx.moveTo(x, top); tempCtx.lineTo(x, bottom); tempCtx.stroke();
            col++;
          }
          let row = 0;
          for (let y = top; y <= bottom + 0.01; y += spacing) {
            const isMajor = major > 0 && row % major === 0;
            tempCtx.strokeStyle = isMajor ? settings.majorColor : settings.minorColor;
            tempCtx.lineWidth = isMajor ? settings.gridThickness : settings.gridThickness / 2;
            tempCtx.beginPath(); tempCtx.moveTo(left, y); tempCtx.lineTo(right, y); tempCtx.stroke();
            row++;
          }
        } else if (settings.gridType === 'dot') {
          tempCtx.fillStyle = settings.minorColor;
          for (let x = left; x <= right + 0.01; x += spacing) {
            for (let y = top; y <= bottom + 0.01; y += spacing) {
              tempCtx.beginPath(); tempCtx.arc(x, y, settings.gridThickness / 2, 0, 2 * Math.PI); tempCtx.fill();
            }
          }
        } else if (settings.gridType === 'isometric') {
          tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
          for (let x = left; x <= right + 0.01; x += spacing) {
            tempCtx.beginPath(); tempCtx.moveTo(x, top); tempCtx.lineTo(x, bottom); tempCtx.stroke();
          }
          const stepC = spacing * Math.sqrt(3);
          const minC = top - 0.57735 * right;
          const maxC = bottom - 0.57735 * left;
          for (let c = minC; c <= maxC; c += stepC) {
            tempCtx.beginPath(); tempCtx.moveTo(left, 0.57735 * left + c); tempCtx.lineTo(right, 0.57735 * right + c); tempCtx.stroke();
          }
          const minC2 = top + 0.57735 * left;
          const maxC2 = bottom + 0.57735 * right;
          for (let c = minC2; c <= maxC2; c += stepC) {
            tempCtx.beginPath(); tempCtx.moveTo(left, -0.57735 * left + c); tempCtx.lineTo(right, -0.57735 * right + c); tempCtx.stroke();
          }
        } else if (settings.gridType === 'polar') {
          const cx = left + (right - left) / 2;
          const cy = top + (bottom - top) / 2;
          const maxRadius = Math.sqrt((right - left) ** 2 + (bottom - top) ** 2) / 2;
          tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
          for (let r = spacing; r <= maxRadius; r += spacing) {
            tempCtx.beginPath(); tempCtx.arc(cx, cy, r, 0, 2 * Math.PI); tempCtx.stroke();
          }
          for (let angle = 0; angle < 360; angle += 15) {
            const rad = (angle * Math.PI) / 180;
            tempCtx.beginPath(); tempCtx.moveTo(cx, cy); tempCtx.lineTo(cx + maxRadius * Math.cos(rad), cy + maxRadius * Math.sin(rad)); tempCtx.stroke();
          }
        } else if (settings.gridType === 'loglog' || settings.gridType === 'semilog') {
          const numDecadesX = settings.gridType === 'loglog' ? 3 : 5;
          const numDecadesY = 4;
          const decWidth = (right - left) / numDecadesX;
          const decHeight = (bottom - top) / numDecadesY;
          if (settings.gridType === 'loglog') {
            for (let d = 0; d < numDecadesX; d++) {
              const dStart = left + d * decWidth;
              tempCtx.strokeStyle = settings.majorColor; tempCtx.lineWidth = settings.gridThickness;
              tempCtx.beginPath(); tempCtx.moveTo(dStart, top); tempCtx.lineTo(dStart, bottom); tempCtx.stroke();
              tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
              for (let k = 2; k <= 9; k++) {
                const x = dStart + Math.log10(k) * decWidth;
                tempCtx.beginPath(); tempCtx.moveTo(x, top); tempCtx.lineTo(x, bottom); tempCtx.stroke();
              }
            }
            tempCtx.strokeStyle = settings.majorColor; tempCtx.lineWidth = settings.gridThickness;
            tempCtx.beginPath(); tempCtx.moveTo(right, top); tempCtx.lineTo(right, bottom); tempCtx.stroke();
          } else {
            for (let x = left; x <= right + 0.01; x += spacing) {
              tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
              tempCtx.beginPath(); tempCtx.moveTo(x, top); tempCtx.lineTo(x, bottom); tempCtx.stroke();
            }
          }
          for (let d = 0; d < numDecadesY; d++) {
            const dStart = bottom - d * decHeight;
            tempCtx.strokeStyle = settings.majorColor; tempCtx.lineWidth = settings.gridThickness;
            tempCtx.beginPath(); tempCtx.moveTo(left, dStart); tempCtx.lineTo(right, dStart); tempCtx.stroke();
            tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
            for (let k = 2; k <= 9; k++) {
              const y = dStart - Math.log10(k) * decHeight;
              tempCtx.beginPath(); tempCtx.moveTo(left, y); tempCtx.lineTo(right, y); tempCtx.stroke();
            }
          }
          tempCtx.strokeStyle = settings.majorColor; tempCtx.lineWidth = settings.gridThickness;
          tempCtx.beginPath(); tempCtx.moveTo(left, top); tempCtx.lineTo(right, top); tempCtx.stroke();
        } else if (settings.gridType === 'hexagonal') {
          const r = spacing; const h = r * Math.sqrt(3);
          tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
          const cols = Math.ceil((right - left) / (r * 1.5)) + 1;
          const rows = Math.ceil((bottom - top) / h) + 1;
          for (let col = -1; col < cols; col++) {
            for (let row = -1; row < rows; row++) {
              const cx = left + col * r * 1.5;
              const cy = top + row * h + (col % 2 === 0 ? 0 : h / 2);
              tempCtx.beginPath();
              for (let i = 0; i < 6; i++) {
                const angle = (i * Math.PI) / 3;
                tempCtx.lineTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle));
              }
              tempCtx.closePath(); tempCtx.stroke();
            }
          }
        } else if (settings.gridType === 'triangular') {
          const dy = spacing * Math.sqrt(3) / 2;
          tempCtx.strokeStyle = settings.minorColor; tempCtx.lineWidth = settings.gridThickness / 2;
          for (let y = top; y <= bottom + 0.01; y += dy) {
            tempCtx.beginPath(); tempCtx.moveTo(left, y); tempCtx.lineTo(right, y); tempCtx.stroke();
          }
          const stepC = spacing;
          const minC = top - 1.73205 * right;
          const maxC = bottom - 1.73205 * left;
          for (let c = minC; c <= maxC; c += stepC) {
            tempCtx.beginPath(); tempCtx.moveTo(left, 1.73205 * left + c); tempCtx.lineTo(right, 1.73205 * right + c); tempCtx.stroke();
          }
          const minC2 = top + 1.73205 * left;
          const maxC2 = bottom + 1.73205 * right;
          for (let c = minC2; c <= maxC2; c += stepC) {
            tempCtx.beginPath(); tempCtx.moveTo(left, -1.73205 * left + c); tempCtx.lineTo(right, -1.73205 * right + c); tempCtx.stroke();
          }
        }

        tempCtx.restore();

        if (settings.showPrintGuides) {
          tempCtx.strokeStyle = settings.majorColor; tempCtx.lineWidth = 0.25; tempCtx.setLineDash([2, 2]);
          tempCtx.beginPath(); tempCtx.rect(left, top, right - left, bottom - top); tempCtx.stroke();
          tempCtx.setLineDash([]);
        }

        if (settings.showCropMarks) {
          tempCtx.strokeStyle = '#000000'; tempCtx.lineWidth = 0.25;
          const size = 5;
          tempCtx.beginPath();
          tempCtx.moveTo(0, top); tempCtx.lineTo(size, top); tempCtx.moveTo(left, 0); tempCtx.lineTo(left, size);
          tempCtx.moveTo(wMm, top); tempCtx.lineTo(wMm - size, top); tempCtx.moveTo(right, 0); tempCtx.lineTo(right, size);
          tempCtx.moveTo(0, bottom); tempCtx.lineTo(size, bottom); tempCtx.moveTo(left, hMm); tempCtx.lineTo(left, hMm - size);
          tempCtx.moveTo(wMm, bottom); tempCtx.lineTo(wMm - size, bottom); tempCtx.moveTo(right, hMm); tempCtx.lineTo(right, hMm - size);
          tempCtx.stroke();
        }

        shapes.forEach(shape => {
          drawSingleShape(tempCtx, shape);
        });

        const doc = new jsPDFClass({
          orientation: settings.orientation === 'portrait' ? 'portrait' : 'landscape',
          unit: 'mm',
          format: settings.paperSize === 'custom' ? [settings.customWidth, settings.customHeight] : settings.paperSize
        });

        const imgData = tempCanvas.toDataURL('image/png');
        doc.addImage(imgData, 'PNG', 0, 0, wMm, hMm);
        doc.save(`graph-paper-${settings.gridType}-${settings.paperSize.toLowerCase()}.pdf`);
      } catch (e) {
        alert('Error generating PDF: ' + e);
      }
    }

    async function exportPDFVector() {
      try {
        const jsPDFClass = await getJsPDF();
        
        const wMm = paperCanvas.width / pixelsPerMm;
        const hMm = paperCanvas.height / pixelsPerMm;

        const doc = new jsPDFClass({
          orientation: settings.orientation === 'portrait' ? 'portrait' : 'landscape',
          unit: 'mm',
          format: settings.paperSize === 'custom' ? [settings.customWidth, settings.customHeight] : settings.paperSize
        });

        doc.setFillColor(settings.backgroundColor);
        doc.rect(0, 0, wMm, hMm, 'F');

        let mL = settings.marginType === 'auto' ? 10 : settings.marginLeft;
        let mR = settings.marginType === 'auto' ? 10 : settings.marginRight;
        let mT = settings.marginType === 'auto' ? 10 : settings.marginTop;
        let mB = settings.marginType === 'auto' ? 10 : settings.marginBottom;
        const left = mL;
        const right = wMm - mR;
        const top = mT;
        const bottom = hMm - mB;

        function clipLine(x1, y1, x2, y2) {
          let t0 = 0, t1 = 1;
          const dx = x2 - x1, dy = y2 - y1;
          
          const edges = [
            { p: -dx, q: x1 - left },
            { p: dx, q: right - x1 },
            { p: -dy, q: y1 - top },
            { p: dy, q: bottom - y1 }
          ];

          for (let i = 0; i < 4; i++) {
            const { p, q } = edges[i];
            if (p === 0) {
              if (q < 0) return null;
            } else {
              const r = q / p;
              if (p < 0) {
                if (r > t1) return null;
                if (r > t0) t0 = r;
              } else {
                if (r < t0) return null;
                if (r < t1) t1 = r;
              }
            }
          }

          return {
            x1: x1 + t0 * dx,
            y1: y1 + t0 * dy,
            x2: x1 + t1 * dx,
            y2: y1 + t1 * dy
          };
        }

        function drawVectorLine(x1, y1, x2, y2, isMajor) {
          const clipped = clipLine(x1, y1, x2, y2);
          if (!clipped) return;
          
          doc.setDrawColor(isMajor ? settings.majorColor : settings.minorColor);
          doc.setLineWidth(isMajor ? settings.gridThickness : settings.gridThickness / 2);
          doc.line(clipped.x1, clipped.y1, clipped.x2, clipped.y2);
        }

        const spacing = settings.gridSpacing;
        const major = settings.majorInterval;

        if (settings.gridType === 'square' || settings.gridType === 'green' || settings.gridType === 'cartesian') {
          let col = 0;
          for (let x = left; x <= right + 0.01; x += spacing) {
            const isMajor = major > 0 && col % major === 0;
            drawVectorLine(x, top, x, bottom, isMajor);
            col++;
          }
          let row = 0;
          for (let y = top; y <= bottom + 0.01; y += spacing) {
            const isMajor = major > 0 && row % major === 0;
            drawVectorLine(left, y, right, y, isMajor);
            row++;
          }
        } else if (settings.gridType === 'dot') {
          doc.setFillColor(settings.majorColor);
          const dotRadius = Math.max(0.3, settings.gridThickness);
          for (let x = left; x <= right + 0.01; x += spacing) {
            for (let y = top; y <= bottom + 0.01; y += spacing) {
              doc.circle(x, y, dotRadius, 'F');
            }
          }
        } else if (settings.gridType === 'isometric') {
          for (let x = left; x <= right + 0.01; x += spacing) {
            drawVectorLine(x, top, x, bottom, false);
          }
          const stepC = spacing * Math.sqrt(3);
          const minC = top - 0.57735 * right;
          const maxC = bottom - 0.57735 * left;
          for (let c = minC; c <= maxC; c += stepC) {
            drawVectorLine(left, 0.57735 * left + c, right, 0.57735 * right + c, false);
          }
          const minC2 = top + 0.57735 * left;
          const maxC2 = bottom + 0.57735 * right;
          for (let c = minC2; c <= maxC2; c += stepC) {
            drawVectorLine(left, -0.57735 * left + c, right, -0.57735 * right + c, false);
          }
        } else if (settings.gridType === 'polar') {
          const cx = left + (right - left) / 2;
          const cy = top + (bottom - top) / 2;
          const maxRadius = Math.sqrt((right - left) ** 2 + (bottom - top) ** 2) / 2;
          
          doc.setDrawColor(settings.minorColor);
          doc.setLineWidth(settings.gridThickness / 2);

          for (let r = spacing; r <= maxRadius; r += spacing) {
            doc.circle(cx, cy, r, 'S');
          }
          for (let angle = 0; angle < 360; angle += 15) {
            const rad = (angle * Math.PI) / 180;
            drawVectorLine(cx, cy, cx + maxRadius * Math.cos(rad), cy + maxRadius * Math.sin(rad), false);
          }
        } else if (settings.gridType === 'loglog' || settings.gridType === 'semilog') {
          const numDecadesX = settings.gridType === 'loglog' ? 3 : 5;
          const numDecadesY = 4;
          const decWidth = (right - left) / numDecadesX;
          const decHeight = (bottom - top) / numDecadesY;

          if (settings.gridType === 'loglog') {
            for (let d = 0; d < numDecadesX; d++) {
              const dStart = left + d * decWidth;
              drawVectorLine(dStart, top, dStart, bottom, true);
              for (let k = 2; k <= 9; k++) {
                const x = dStart + Math.log10(k) * decWidth;
                drawVectorLine(x, top, x, bottom, false);
              }
            }
            drawVectorLine(right, top, right, bottom, true);
          } else {
            for (let x = left; x <= right + 0.01; x += spacing) {
              drawVectorLine(x, top, x, bottom, false);
            }
          }

          for (let d = 0; d < numDecadesY; d++) {
            const dStart = bottom - d * decHeight;
            drawVectorLine(left, dStart, right, dStart, true);
            for (let k = 2; k <= 9; k++) {
              const y = dStart - Math.log10(k) * decHeight;
              drawVectorLine(left, y, right, y, false);
            }
          }
          drawVectorLine(left, top, right, top, true);
        } else if (settings.gridType === 'hexagonal') {
          const r = spacing; const h = r * Math.sqrt(3);
          const cols = Math.ceil((right - left) / (r * 1.5)) + 1;
          const rows = Math.ceil((bottom - top) / h) + 1;
          
          doc.setDrawColor(settings.minorColor);
          doc.setLineWidth(settings.gridThickness / 2);
          for (let col = -1; col < cols; col++) {
            for (let row = -1; row < rows; row++) {
              const cx = left + col * r * 1.5;
              const cy = top + row * h + (col % 2 === 0 ? 0 : h / 2);
              for (let i = 0; i < 6; i++) {
                const angle1 = (i * Math.PI) / 3;
                const angle2 = (((i + 1) % 6) * Math.PI) / 3;
                drawVectorLine(cx + r * Math.cos(angle1), cy + r * Math.sin(angle1), cx + r * Math.cos(angle2), cy + r * Math.sin(angle2), false);
              }
            }
          }
        } else if (settings.gridType === 'triangular') {
          const dy = spacing * Math.sqrt(3) / 2;
          for (let y = top; y <= bottom + 0.01; y += dy) {
            drawVectorLine(left, y, right, y, false);
          }
          const stepC = spacing;
          const minC = top - 1.73205 * right;
          const maxC = bottom - 1.73205 * left;
          for (let c = minC; c <= maxC; c += stepC) {
            drawVectorLine(left, 1.73205 * left + c, right, 1.73205 * right + c, false);
          }
          const minC2 = top + 1.73205 * left;
          const maxC2 = bottom + 1.73205 * right;
          for (let c = minC2; c <= maxC2; c += stepC) {
            drawVectorLine(left, -1.73205 * left + c, right, -1.73205 * right + c, false);
          }
        }

        if (settings.showPrintGuides) {
          doc.setDrawColor(settings.majorColor);
          doc.setLineWidth(0.25);
          doc.setLineDashPattern([2, 2], 0);
          doc.rect(left, top, right - left, bottom - top, 'S');
          doc.setLineDashPattern([], 0);
        }

        if (settings.showCropMarks) {
          doc.setDrawColor('#000000');
          doc.setLineWidth(0.25);
          const size = 5;
          doc.line(0, top, size, top); doc.line(left, 0, left, size);
          doc.line(wMm, top, wMm - size, top); doc.line(right, 0, right, size);
          doc.line(0, bottom, size, bottom); doc.line(left, hMm, left, hMm - size);
          doc.line(wMm, bottom, wMm - size, bottom); doc.line(right, hMm, right, hMm - size);
        }

        shapes.forEach(shape => {
          doc.setDrawColor(shape.color);
          doc.setLineWidth(shape.width);
          doc.setLineCap('round');
          
          if (shape.type === 'pencil' || shape.type === 'pen') {
            for (let i = 0; i < shape.points.length - 1; i++) {
              doc.line(shape.points[i].x, shape.points[i].y, shape.points[i+1].x, shape.points[i+1].y);
            }
          } else if (shape.type === 'line') {
            if (shape.points.length < 2) return;
            doc.line(shape.points[0].x, shape.points[0].y, shape.points[1].x, shape.points[1].y);
          } else if (shape.type === 'arrow') {
            if (shape.points.length < 2) return;
            const p0 = shape.points[0];
            const p1 = shape.points[1];
            doc.line(p0.x, p0.y, p1.x, p1.y);
            const angle = Math.atan2(p1.y - p0.y, p1.x - p0.x);
            const headlen = 4;
            doc.line(p1.x, p1.y, p1.x - headlen * Math.cos(angle - Math.PI / 6), p1.y - headlen * Math.sin(angle - Math.PI / 6));
            doc.line(p1.x, p1.y, p1.x - headlen * Math.cos(angle + Math.PI / 6), p1.y - headlen * Math.sin(angle + Math.PI / 6));
          } else if (shape.type === 'rect') {
            if (shape.points.length < 2) return;
            const x = Math.min(shape.points[0].x, shape.points[1].x);
            const y = Math.min(shape.points[0].y, shape.points[1].y);
            const w = Math.abs(shape.points[0].x - shape.points[1].x);
            const h = Math.abs(shape.points[0].y - shape.points[1].y);
            doc.rect(x, y, w, h, 'S');
          } else if (shape.type === 'circle') {
            if (shape.points.length < 2) return;
            const r = Math.hypot(shape.points[1].x - shape.points[0].x, shape.points[1].y - shape.points[0].y);
            doc.circle(shape.points[0].x, shape.points[0].y, r, 'S');
          } else if (shape.type === 'text') {
            if (shape.points.length < 1) return;
            doc.setTextColor(shape.color);
            doc.setFontSize(shape.width * 4.5);
            doc.text(shape.text || '', shape.points[0].x, shape.points[0].y);
          } else if (shape.type === 'eraser') {
            doc.setDrawColor(settings.backgroundColor);
            doc.setLineWidth(shape.width);
            for (let i = 0; i < shape.points.length - 1; i++) {
              doc.line(shape.points[i].x, shape.points[i].y, shape.points[i+1].x, shape.points[i+1].y);
            }
          }
        });

        doc.save(`graph-paper-${settings.gridType}-${settings.paperSize.toLowerCase()}-vector.pdf`);
      } catch (e) {
        alert('Error generating Vector PDF: ' + e);
      }
    }

    function getShareableUrl() {
      const params = new URLSearchParams();
      params.set('type', settings.gridType);
      params.set('size', settings.paperSize);
      params.set('w', settings.customWidth.toString());
      params.set('h', settings.customHeight.toString());
      params.set('orient', settings.orientation);
      params.set('unit', settings.spacingUnit);
      params.set('spacing', settings.gridSpacing.toString());
      params.set('major', settings.majorInterval.toString());
      params.set('theme', settings.theme);
      params.set('bg', settings.backgroundColor);
      params.set('minorColor', settings.minorColor);
      params.set('majorColor', settings.majorColor);
      params.set('opacity', settings.gridOpacity.toString());
      params.set('thickness', settings.gridThickness.toString());
      params.set('marginTop', settings.marginTop.toString());
      params.set('marginBottom', settings.marginBottom.toString());
      params.set('marginLeft', settings.marginLeft.toString());
      params.set('marginRight', settings.marginRight.toString());
      
      return window.location.origin + window.location.pathname + '#' + params.toString();
    }

    function loadFromUrl() {
      const hash = window.location.hash.substring(1);
      if (!hash) return;
      try {
        const params = new URLSearchParams(hash);
        if (params.has('type')) settings.gridType = params.get('type');
        if (params.has('size')) settings.paperSize = params.get('size');
        if (params.has('w')) settings.customWidth = parseFloat(params.get('w'));
        if (params.has('h')) settings.customHeight = parseFloat(params.get('h'));
        if (params.has('orient')) settings.orientation = params.get('orient');
        if (params.has('unit')) settings.spacingUnit = params.get('unit');
        if (params.has('spacing')) settings.gridSpacing = parseFloat(params.get('spacing'));
        if (params.has('major')) settings.majorInterval = parseInt(params.get('major'));
        if (params.has('theme')) settings.theme = params.get('theme');
        if (params.has('bg')) settings.backgroundColor = params.get('bg');
        if (params.has('minorColor')) settings.minorColor = params.get('minorColor');
        if (params.has('majorColor')) settings.majorColor = params.get('majorColor');
        if (params.has('opacity')) settings.gridOpacity = parseFloat(params.get('opacity'));
        if (params.has('thickness')) settings.gridThickness = parseFloat(params.get('thickness'));
        if (params.has('marginTop')) settings.marginTop = parseFloat(params.get('marginTop'));
        if (params.has('marginBottom')) settings.marginBottom = parseFloat(params.get('marginBottom'));
        if (params.has('marginLeft')) settings.marginLeft = parseFloat(params.get('marginLeft'));
        if (params.has('marginRight')) settings.marginRight = parseFloat(params.get('marginRight'));
      } catch (e) {
        console.warn('Could not parse shared URL hash parameters:', e);
      }
    }

    window.addEventListener('gmo-theme-changed', (e) => {
      // Keep the paper theme green (or custom, whatever user selected)
      // Do not auto-change it to dark/classic
      drawPaper();
    });

    init();
  });

  function generateSVGString(W, H, mL, mR, mT, mB, settings, shapes) {
    const left = mL;
    const right = W - mR;
    const top = mT;
    const bottom = H - mB;
    
    let svg = `<svg viewBox="0 0 ${W} ${H}" width="${W}mm" height="${H}mm" xmlns="http://www.w3.org/2000/svg" style="background-color: ${settings.backgroundColor}">`;
    
    const minorStyle = `stroke="${settings.minorColor}" stroke-width="${settings.gridThickness / 2}" opacity="${settings.gridOpacity}"`;
    const majorStyle = `stroke="${settings.majorColor}" stroke-width="${settings.gridThickness}" opacity="${settings.gridOpacity}"`;
    
    svg += `<defs><clipPath id="grid-clip"><rect x="${left}" y="${top}" width="${right - left}" height="${bottom - top}" /></clipPath></defs>`;
    svg += `<g clip-path="url(#grid-clip)">`;
    
    if (settings.gridType === 'square' || settings.gridType === 'green' || settings.gridType === 'cartesian') {
      const spacing = settings.gridSpacing;
      const major = settings.majorInterval;
      
      let pathMinor = '';
      let pathMajor = '';
      
      let col = 0;
      for (let x = left; x <= right + 0.01; x += spacing) {
        const isMajor = major > 0 && col % major === 0;
        if (isMajor) {
          pathMajor += `M ${x} ${top} L ${x} ${bottom} `;
        } else {
          pathMinor += `M ${x} ${top} L ${x} ${bottom} `;
        }
        col++;
      }
      
      let row = 0;
      for (let y = top; y <= bottom + 0.01; y += spacing) {
        const isMajor = major > 0 && row % major === 0;
        if (isMajor) {
          pathMajor += `M ${left} ${y} L ${right} ${y} `;
        } else {
          pathMinor += `M ${left} ${y} L ${right} ${y} `;
        }
        row++;
      }
      
      if (pathMinor) svg += `<path d="${pathMinor}" ${minorStyle} fill="none" />`;
      if (pathMajor) svg += `<path d="${pathMajor}" ${majorStyle} fill="none" />`;
      
      if (settings.gridType === 'cartesian') {
        const cx = left + (right - left) / 2;
        const cy = top + (bottom - top) / 2;
        
        svg += `<line x1="${left}" y1="${cy}" x2="${right}" y2="${cy}" stroke="${settings.majorColor}" stroke-width="${settings.gridThickness * 1.5}" />`;
        svg += `<line x1="${cx}" y1="${top}" x2="${cx}" y2="${bottom}" stroke="${settings.majorColor}" stroke-width="${settings.gridThickness * 1.5}" />`;
        
        svg += `<g font-family="sans-serif" font-size="2.5" fill="${settings.majorColor}" text-anchor="middle">`;
        let idx = 0;
        for (let x = cx + spacing; x <= right; x += spacing) {
          idx++;
          if (idx % 2 === 0) svg += `<text x="${x}" y="${cy + 3.5}">${idx}</text>`;
        }
        idx = 0;
        for (let x = cx - spacing; x >= left; x -= spacing) {
          idx++;
          if (idx % 2 === 0) svg += `<text x="${x}" y="${cy + 3.5}">-${idx}</text>`;
        }
        idx = 0;
        for (let y = cy - spacing; y >= top; y -= spacing) {
          idx++;
          if (idx % 2 === 0) svg += `<text x="${cx - 1.5}" y="${y + 0.8}" text-anchor="end">${idx}</text>`;
        }
        idx = 0;
        for (let y = cy + spacing; y <= bottom; y += spacing) {
          idx++;
          if (idx % 2 === 0) svg += `<text x="${cx - 1.5}" y="${y + 0.8}" text-anchor="end">-${idx}</text>`;
        }
        svg += `</g>`;
      }
    } else if (settings.gridType === 'dot') {
      const spacing = settings.gridSpacing;
      let dots = '';
      const dotRadius = Math.max(0.3, settings.gridThickness);
      for (let x = left; x <= right + 0.01; x += spacing) {
        for (let y = top; y <= bottom + 0.01; y += spacing) {
          dots += `<circle cx="${x}" cy="${y}" r="${dotRadius}" fill="${settings.majorColor}" opacity="${settings.gridOpacity}" />`;
        }
      }
      svg += dots;
    } else if (settings.gridType === 'isometric') {
      const spacing = settings.gridSpacing;
      
      let pathV = '';
      for (let x = left; x <= right + 0.01; x += spacing) {
        pathV += `M ${x} ${top} L ${x} ${bottom} `;
      }
      svg += `<path d="${pathV}" ${minorStyle} fill="none" />`;
      
      let path30 = '';
      const stepC = spacing * Math.sqrt(3);
      const minC = top - 0.57735 * right;
      const maxC = bottom - 0.57735 * left;
      for (let c = minC; c <= maxC; c += stepC) {
        path30 += `M ${left} ${0.57735 * left + c} L ${right} ${0.57735 * right + c} `;
      }
      svg += `<path d="${path30}" ${minorStyle} fill="none" />`;
      
      let path150 = '';
      const minC2 = top + 0.57735 * left;
      const maxC2 = bottom + 0.57735 * right;
      for (let c = minC2; c <= maxC2; c += stepC) {
        path150 += `M ${left} ${-0.57735 * left + c} L ${right} ${-0.57735 * right + c} `;
      }
      svg += `<path d="${path150}" ${minorStyle} fill="none" />`;
    } else if (settings.gridType === 'polar') {
      const spacing = settings.gridSpacing;
      const cx = left + (right - left) / 2;
      const cy = top + (bottom - top) / 2;
      const maxRadius = Math.sqrt((right - left) ** 2 + (bottom - top) ** 2) / 2;
      
      let circles = '';
      for (let r = spacing; r <= maxRadius; r += spacing) {
        circles += `<circle cx="${cx}" cy="${cy}" r="${r}" ${minorStyle} fill="none" />`;
      }
      svg += circles;
      
      let rads = '';
      for (let angle = 0; angle < 360; angle += 15) {
        const rad = (angle * Math.PI) / 180;
        const x2 = cx + maxRadius * Math.cos(rad);
        const y2 = cy + maxRadius * Math.sin(rad);
        rads += `M ${cx} ${cy} L ${x2} ${y2} `;
      }
      svg += `<path d="${rads}" ${minorStyle} fill="none" />`;
    } else if (settings.gridType === 'loglog' || settings.gridType === 'semilog') {
      const numDecadesX = settings.gridType === 'loglog' ? 3 : 5;
      const numDecadesY = 4;
      const decWidth = (right - left) / numDecadesX;
      const decHeight = (bottom - top) / numDecadesY;
      
      let pathGrid = '';
      let pathMajor = '';
      
      if (settings.gridType === 'loglog') {
        for (let d = 0; d < numDecadesX; d++) {
          const dStart = left + d * decWidth;
          pathMajor += `M ${dStart} ${top} L ${dStart} ${bottom} `;
          for (let k = 1; k <= 10; k++) {
            const x = dStart + Math.log10(k) * decWidth;
            pathGrid += `M ${x} ${top} L ${x} ${bottom} `;
          }
        }
        pathMajor += `M ${right} ${top} L ${right} ${bottom} `;
      } else {
        const spacing = settings.gridSpacing;
        for (let x = left; x <= right + 0.01; x += spacing) {
          pathGrid += `M ${x} ${top} L ${x} ${bottom} `;
        }
      }
      
      for (let d = 0; d < numDecadesY; d++) {
        const dStart = bottom - d * decHeight;
        pathMajor += `M ${left} ${dStart} L ${right} ${dStart} `;
        for (let k = 1; k <= 10; k++) {
          const y = dStart - Math.log10(k) * decHeight;
          pathGrid += `M ${left} ${y} L ${right} ${y} `;
        }
      }
      pathMajor += `M ${left} ${top} L ${right} ${top} `;
      
      svg += `<path d="${pathGrid}" ${minorStyle} fill="none" />`;
      svg += `<path d="${pathMajor}" ${majorStyle} fill="none" />`;
    } else if (settings.gridType === 'hexagonal') {
      const r = spacing; const h = r * Math.sqrt(3);
      let hexPath = '';
      
      const cols = Math.ceil((right - left) / (r * 1.5)) + 1;
      const rows = Math.ceil((bottom - top) / h) + 1;
      
      for (let col = -1; col < cols; col++) {
        for (let row = -1; row < rows; row++) {
          const cx = left + col * r * 1.5;
          const cy = top + row * h + (col % 2 === 0 ? 0 : h / 2);
          
          for (let i = 0; i < 6; i++) {
            const angle = (i * Math.PI) / 3;
            const x = cx + r * Math.cos(angle);
            const y = cy + r * Math.sin(angle);
            if (i === 0) hexPath += `M ${x} ${y} `;
            else hexPath += `L ${x} ${y} `;
          }
          hexPath += `Z `;
        }
      }
      svg += `<path d="${hexPath}" ${minorStyle} fill="none" />`;
    } else if (settings.gridType === 'triangular') {
      const spacing = settings.gridSpacing;
      const dy = spacing * Math.sqrt(3) / 2;
      
      let pathH = '';
      for (let y = top; y <= bottom + 0.01; y += dy) {
        pathH += `M ${left} ${y} L ${right} ${y} `;
      }
      svg += `<path d="${pathH}" ${minorStyle} fill="none" />`;
      
      let path60 = '';
      const stepC = spacing;
      const minC = top - 1.73205 * right;
      const maxC = bottom - 1.73205 * left;
      for (let c = minC; c <= maxC; c += stepC) {
        path60 += `M ${left} ${1.73205 * left + c} L ${right} ${1.73205 * right + c} `;
      }
      svg += `<path d="${path60}" ${minorStyle} fill="none" />`;
      
      let path120 = '';
      const minC2 = top + 1.73205 * left;
      const maxC2 = bottom + 1.73205 * right;
      for (let c = minC2; c <= maxC2; c += stepC) {
        path120 += `M ${left} ${-1.73205 * left + c} L ${right} ${-1.73205 * right + c} `;
      }
      svg += `<path d="${path120}" ${minorStyle} fill="none" />`;
    }
    
    svg += `</g>`;
    
    if (settings.showPrintGuides) {
      svg += `<rect x="${left}" y="${top}" width="${right - left}" height="${bottom - top}" stroke="${settings.majorColor}" stroke-width="0.3" stroke-dasharray="2,2" fill="none" />`;
    }
    
    if (settings.showCropMarks) {
      const size = 5;
      svg += `<path d="M 0 ${top} L ${size} ${top} M ${left} 0 L ${left} ${size}" stroke="#000" stroke-width="0.3" />`;
      svg += `<path d="M ${W} ${top} L ${W - size} ${top} M ${right} 0 L ${right} ${size}" stroke="#000" stroke-width="0.3" />`;
      svg += `<path d="M 0 ${bottom} L ${size} ${bottom} M ${left} ${H} L ${left} ${H - size}" stroke="#000" stroke-width="0.3" />`;
      svg += `<path d="M ${W} ${bottom} L ${W - size} ${bottom} M ${right} ${H} L ${right} ${H - size}" stroke="#000" stroke-width="0.3" />`;
    }
    
    shapes.forEach(shape => {
      const strokeStyle = `stroke="${shape.color}" stroke-width="${shape.width}" stroke-linecap="round" stroke-linejoin="round" fill="none"`;
      if (shape.type === 'pencil' || shape.type === 'pen') {
        if (shape.points.length < 1) return;
        let path = `M ${shape.points[0].x} ${shape.points[0].y} `;
        for (let i = 1; i < shape.points.length; i++) {
          path += `L ${shape.points[i].x} ${shape.points[i].y} `;
        }
        svg += `<path d="${path}" ${strokeStyle} />`;
      } else if (shape.type === 'line') {
        if (shape.points.length < 2) return;
        svg += `<line x1="${shape.points[0].x}" y1="${shape.points[0].y}" x2="${shape.points[1].x}" y2="${shape.points[1].y}" ${strokeStyle} />`;
      } else if (shape.type === 'arrow') {
        if (shape.points.length < 2) return;
        const p0 = shape.points[0];
        const p1 = shape.points[1];
        svg += `<line x1="${p0.x}" y1="${p0.y}" x2="${p1.x}" y2="${p1.y}" ${strokeStyle} />`;
        const angle = Math.atan2(p1.y - p0.y, p1.x - p0.x);
        const headlen = 4;
        const xA = p1.x - headlen * Math.cos(angle - Math.PI / 6);
        const yA = p1.y - headlen * Math.sin(angle - Math.PI / 6);
        const xB = p1.x - headlen * Math.cos(angle + Math.PI / 6);
        const yB = p1.y - headlen * Math.sin(angle + Math.PI / 6);
        svg += `<path d="M ${xA} ${yA} L ${p1.x} ${p1.y} L ${xB} ${yB}" stroke="${shape.color}" stroke-width="${shape.width}" stroke-linecap="round" fill="none" />`;
      } else if (shape.type === 'rect') {
        if (shape.points.length < 2) return;
        const x = Math.min(shape.points[0].x, shape.points[1].x);
        const y = Math.min(shape.points[0].y, shape.points[1].y);
        const w = Math.abs(shape.points[0].x - shape.points[1].x);
        const h = Math.abs(shape.points[0].y - shape.points[1].y);
        svg += `<rect x="${x}" y="${y}" width="${w}" height="${h}" ${strokeStyle} />`;
      } else if (shape.type === 'circle') {
        if (shape.points.length < 2) return;
        const r = Math.hypot(shape.points[1].x - shape.points[0].x, shape.points[1].y - shape.points[0].y);
        svg += `<circle cx="${shape.points[0].x}" cy="${shape.points[0].y}" r="${r}" ${strokeStyle} />`;
      } else if (shape.type === 'text') {
        if (shape.points.length < 1) return;
        svg += `<text x="${shape.points[0].x}" y="${shape.points[0].y}" fill="${shape.color}" font-family="sans-serif" font-size="${shape.width * 1.5}" text-anchor="start">${shape.text || ''}</text>`;
      } else if (shape.type === 'eraser') {
        if (shape.points.length < 1) return;
        let path = `M ${shape.points[0].x} ${shape.points[0].y} `;
        for (let i = 1; i < shape.points.length; i++) {
          path += `L ${shape.points[i].x} ${shape.points[i].y} `;
        }
        svg += `<path d="${path}" stroke="${settings.backgroundColor}" stroke-width="${shape.width}" stroke-linecap="round" stroke-linejoin="round" fill="none" />`;
      }
    });
    
    svg += `</svg>`;
    return svg;
  }
</script>

