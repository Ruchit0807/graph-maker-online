---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Contact Us – Graph Maker Online"
  description="Have feedback, feature requests, or questions? Contact the Graph Maker Online team and let us know how we can improve our graphing tool."
  canonicalUrl="https://graphmakeronline.com/contact"
>
  <div class="flex flex-col min-h-screen bg-canvas-soft text-ink transition-colors duration-150">
    <Header isEditor={false} />

    <main class="flex-1 py-16 sm:py-24 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto w-full">
      <!-- Title Section -->
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="inline-flex items-center gap-2 rounded-full px-3.5 py-1.5 text-xs font-semibold bg-canvas border border-hairline shadow-xs mb-6 select-none text-ink">
          Support &amp; Feedback
        </span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight mb-6">
          Contact <span class="bg-gradient-to-r from-violet via-highlight-pink to-link-blue bg-clip-text text-transparent">Our Team</span>
        </h1>
        <p class="text-base sm:text-lg text-mute leading-relaxed">
          Have a feature request, found a bug, or want to collaborate? We'd love to hear from you.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- Contact Details Columns -->
        <div class="lg:col-span-5 space-y-6">
          <div class="rounded-md border border-hairline bg-canvas p-6 shadow-xs">
            <h3 class="text-sm font-semibold text-ink mb-3">Direct Support</h3>
            <p class="text-xs text-mute leading-relaxed mb-4">
              For immediate support, bug submissions, or general inquiries, you can email us directly:
            </p>
            <a href="mailto:graphmakeronline@gmail.com" class="text-xs font-mono font-semibold text-link-blue hover:underline">
              graphmakeronline@gmail.com
            </a>
          </div>

          <div class="rounded-md border border-hairline bg-canvas p-6 shadow-xs">
            <h3 class="text-sm font-semibold text-ink mb-3 font-sans">Open Source &amp; Tech</h3>
            <p class="text-xs text-mute leading-relaxed">
              This app is powered by high-performance canvas vectors and runs completely client-side. We value community contributions and feedback to make it the most lightweight graphing tool on the web.
            </p>
          </div>
        </div>

        <!-- Contact Form Box -->
        <div class="lg:col-span-7">
          <div class="rounded-md border border-hairline bg-canvas p-6 sm:p-8 shadow-xs relative overflow-hidden" id="form-container">
            
            <!-- Success State overlay (hidden initially) -->
            <div id="success-overlay" class="absolute inset-0 bg-canvas/95 backdrop-blur-xs z-10 flex flex-col items-center justify-center p-6 text-center transition-all duration-300 transform translate-y-full opacity-0">
              <div class="h-12 w-12 rounded-full bg-success/10 text-success flex items-center justify-center mb-6">
                <svg class="h-6 w-6 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-ink mb-2">Message Sent!</h3>
              <p class="text-xs text-mute max-w-xs leading-relaxed mb-6">
                Thank you for reaching out. We have received your message and our team will get back to you as soon as possible.
              </p>
              <button 
                id="reset-form-btn"
                class="px-4 py-2 bg-canvas-soft border border-hairline hover:bg-canvas-soft-2 rounded-sm text-xs font-semibold text-ink transition-colors"
              >
                Send Another Message
              </button>
            </div>

            <form id="contact-form" class="space-y-4">
              <!-- Name Input -->
              <div>
                <label for="name" class="block text-[10px] font-semibold uppercase tracking-wider text-mute mb-1.5">Your Name</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required
                  placeholder="John Doe"
                  class="w-full h-10 px-3 text-xs bg-canvas-soft border border-hairline hover:border-hairline-strong focus:border-primary focus:outline-none rounded-sm transition-colors text-ink placeholder:text-mute/50"
                />
              </div>

              <!-- Email Input -->
              <div>
                <label for="email" class="block text-[10px] font-semibold uppercase tracking-wider text-mute mb-1.5">Email Address</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required
                  placeholder="john@example.com"
                  class="w-full h-10 px-3 text-xs bg-canvas-soft border border-hairline hover:border-hairline-strong focus:border-primary focus:outline-none rounded-sm transition-colors text-ink placeholder:text-mute/50"
                />
              </div>

              <!-- Subject Input -->
              <div>
                <label for="subject" class="block text-[10px] font-semibold uppercase tracking-wider text-mute mb-1.5">Subject</label>
                <input 
                  type="text" 
                  id="subject" 
                  name="subject" 
                  required
                  placeholder="Feedback, Feature Request, or Inquiry"
                  class="w-full h-10 px-3 text-xs bg-canvas-soft border border-hairline hover:border-hairline-strong focus:border-primary focus:outline-none rounded-sm transition-colors text-ink placeholder:text-mute/50"
                />
              </div>

              <!-- Message Input -->
              <div>
                <label for="message" class="block text-[10px] font-semibold uppercase tracking-wider text-mute mb-1.5">Message</label>
                <textarea 
                  id="message" 
                  name="message" 
                  required
                  rows="5"
                  placeholder="How can we help you?"
                  class="w-full p-3 text-xs bg-canvas-soft border border-hairline hover:border-hairline-strong focus:border-primary focus:outline-none rounded-sm transition-colors text-ink placeholder:text-mute/50 resize-none"
                ></textarea>
              </div>

              <!-- Submit CTA -->
              <button 
                type="submit" 
                id="submit-btn"
                class="w-full h-10 bg-primary text-xs font-semibold text-on-primary hover:bg-primary/90 focus:outline-none transition-colors rounded-sm flex items-center justify-center gap-2 shadow-xs cursor-pointer"
              >
                <span id="btn-text">Submit Message</span>
                <!-- Loading Spinner (hidden initially) -->
                <svg id="loading-spinner" class="animate-spin h-3.5 w-3.5 text-on-primary hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const spinner = document.getElementById('loading-spinner');
  const successOverlay = document.getElementById('success-overlay');
  const resetBtn = document.getElementById('reset-form-btn');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    // Disable button & show spinner
    submitBtn?.setAttribute('disabled', 'true');
    submitBtn?.classList.add('opacity-80', 'cursor-not-allowed');
    btnText?.classList.add('hidden');
    spinner?.classList.remove('hidden');

    // Simulate standard submission loading time
    setTimeout(() => {
      // Show success modal overlay
      successOverlay?.classList.remove('translate-y-full', 'opacity-0');
      successOverlay?.classList.add('translate-y-0', 'opacity-100');

      // Reset button state
      submitBtn?.removeAttribute('disabled');
      submitBtn?.classList.remove('opacity-80', 'cursor-not-allowed');
      btnText?.classList.remove('hidden');
      spinner?.classList.add('hidden');
      form.reset();
    }, 1200);
  });

  resetBtn?.addEventListener('click', () => {
    // Hide success overlay
    successOverlay?.classList.remove('translate-y-0', 'opacity-100');
    successOverlay?.classList.add('translate-y-full', 'opacity-0');
  });
</script>
