---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Internal Server Error (500) – Graph Maker Online"
  description="The mathematical server encountered an unexpected calculation error. Try resetting the graph editor workspace."
>
  <div class="flex flex-col min-h-screen bg-canvas-soft text-ink transition-colors duration-150">
    <Header />

    <main class="flex-1 flex flex-col items-center justify-center py-16 sm:py-24 px-4 max-w-4xl mx-auto w-full text-center relative overflow-hidden">
      <!-- Grid backdrop decoration -->
      <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05] bg-radial-[circle_at_1px_1px] bg-[size:20px_20px] bg-[#171717] dark:bg-[#ffffff] pointer-events-none"></div>

      <!-- Theme/Math Thematic Illustration -->
      <div class="relative w-full max-w-md h-48 border border-hairline bg-canvas rounded-md shadow-xs p-6 mb-8 flex items-center justify-center overflow-hidden">
        <!-- SVG Grid & Axes -->
        <svg class="absolute inset-0 w-full h-full text-hairline" xmlns="http://www.w3.org/2000/svg">
          <!-- Grid lines -->
          <line x1="0" y1="50%" x2="100%" y2="50%" stroke="currentColor" stroke-width="1.5" />
          <line x1="50%" y1="0" x2="50%" y2="100%" stroke="currentColor" stroke-width="1.5" />
          
          <!-- Discontinuous Math Curve Plot -->
          <!-- Left segment: quadratic rising -->
          <path d="M 20 160 Q 100 120 200 80" fill="none" stroke="#f5a623" stroke-width="2.5" />
          <!-- Open circle for discontinuity limit at x=200 -->
          <circle cx="200" cy="80" r="4.5" fill="var(--color-canvas, #ffffff)" stroke="#f5a623" stroke-width="2" />
          
          <!-- Right segment starting from a different y-level (discontinuity gap) -->
          <path d="M 200 40 Q 300 20 400 30" fill="none" stroke="#f5a623" stroke-width="2.5" stroke-dasharray="3 3" />
          <circle cx="200" cy="40" r="4.5" fill="#f5a623" />
          
          <!-- Dotted vertical line linking them at the discontinuity point -->
          <line x1="200" y1="40" x2="200" y2="80" stroke="#e00" stroke-width="1" stroke-dasharray="2 2" />
        </svg>

        <!-- Discontinuity Indicator -->
        <div class="relative z-10 flex flex-col items-center">
          <span class="font-mono text-xs text-error bg-error/10 px-2 py-0.5 rounded-sm border border-error/20">
            lim f(x) ≠ f(500)
          </span>
          <span class="text-[9px] font-mono uppercase tracking-wider text-mute mt-1.5">
            Calculation Discontinuity
          </span>
        </div>
      </div>

      <!-- Text Section -->
      <div class="max-w-md mx-auto space-y-4">
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight bg-gradient-to-r from-f5a623 via-error to-[#ff0080] bg-clip-text text-transparent">
          500 Error
        </h1>
        <h2 class="text-xl sm:text-2xl font-bold text-ink">
          Internal Calculation Discontinuity
        </h2>
        <p class="text-xs sm:text-sm text-body leading-relaxed max-w-sm mx-auto">
          The editor has run into an undefined state or file system error. Resetting the workspace session will restore normal mathematical operations.
        </p>
      </div>

      <!-- Action Buttons -->
      <div class="mt-8 flex flex-wrap gap-3 items-center justify-center">
        <button 
          id="reset-workspace-btn"
          class="h-9 inline-flex items-center justify-center rounded-sm bg-primary px-5 text-xs font-semibold text-on-primary hover:bg-primary/95 transition-colors shadow-xs"
        >
          Reset Workspace Session
        </button>
        <a 
          href="/contact" 
          class="h-9 inline-flex items-center justify-center rounded-sm border border-hairline bg-canvas px-5 text-xs font-medium text-ink hover:bg-canvas-soft-2 transition-colors"
        >
          Contact Support
        </a>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<script>
  // Simple action handler to clear localStorage and reload editor
  document.getElementById('reset-workspace-btn')?.addEventListener('click', () => {
    try {
      localStorage.clear();
    } catch(e) {}
    window.location.href = '/';
  });
</script>
